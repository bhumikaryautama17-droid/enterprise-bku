<script>
/**
 * Bara Indah Sinergi Group - Workflow Approval Web App
 * Client-side Interactivity (JavaScript.html)
 */

// Global State
let currentUser = {};
let dropdownData = {};
let charts = {};
let activeReviewDoc = null;

// Initialize application on load
function initOnLoad() {
  checkLoginSession();
  setupNavigation();
  setupFormHandlers();
  setupSignatureCanvas();
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initOnLoad);
} else {
  initOnLoad();
}

/**
 * SESSION MANAGEMENT & LOGIN CONTROLLERS
 */
function checkLoginSession() {
  const session = sessionStorage.getItem('currentUser');
  if (session) {
    currentUser = JSON.parse(session);
    document.getElementById('login-page').style.display = 'none';
    updateHeaderProfile();
    loadDashboard();
    loadDropdownData();
  } else {
    document.getElementById('login-page').style.display = 'flex';
    renderDemoChips();
  }
}

function renderDemoChips() {
  const container = document.getElementById('demo-users-chips');
  const demoUsersList = [
    { username: 'mona.asrani', name: 'Mona Asrani', role: 'SPV HR' },
    { username: 'rosalia.natalia', name: 'Rosalia Natalia', role: 'PM' },
    { username: 'putri.amalia', name: 'Putri Amalia', role: 'Finance' },
    { username: 'rosmina.rabbang', name: 'Rosmina Rabbang', role: 'SPV SHE' },
    { username: 'erwin.eka', name: 'Erwin Eka', role: 'SPV Ext' },
    { username: 'yusril', name: 'Yusril', role: 'SPV QAQC' },
    { username: 'roymon.biang', name: 'Roymon Biang', role: 'SPV Eng' },
    { username: 'muh.said', name: 'Muh. Said', role: 'SPV Plant' },
    { username: 'laode.rusman', name: 'Laode Rusman', role: 'SPV Ekspl' },
    { username: 'idul.yusuf', name: 'Idul Yusuf', role: 'User' },
    { username: 'saiful.basri', name: 'Saiful Basri', role: 'User' },
    { username: 'admin', name: 'System Admin', role: 'IT' }
  ];
  
  container.innerHTML = demoUsersList.map(u => 
    `<div class="account-chip" onclick="fillDemoCredentials('${u.username}')" style="display:inline-flex; align-items:center; gap:4px; padding:4px 8px; background:var(--bg-tertiary); border:1px solid var(--border-color); border-radius:20px; font-size:10px; cursor:pointer; margin:2px; color:var(--text-secondary); transition: var(--transition-fast);">
       <i class="fas fa-user-circle" style="font-size:9px; color:var(--accent-cyan);"></i> ${u.name}
     </div>`
  ).join('');
}

function fillDemoCredentials(username) {
  document.getElementById('login-username').value = username;
  document.getElementById('login-password').value = 'BARAindah@2026';
}

function handleLoginSubmit(e) {
  e.preventDefault();
  const user = document.getElementById('login-username').value;
  const pass = document.getElementById('login-password').value;
  const errMsg = document.getElementById('login-error-message');
  
  errMsg.style.display = 'none';
  showLoading(true);
  
  google.script.run.withSuccessHandler(function(res) {
    showLoading(false);
    if (res.success) {
      currentUser = res.user;
      sessionStorage.setItem('currentUser', JSON.stringify(currentUser));
      document.getElementById('login-page').style.display = 'none';
      updateHeaderProfile();
      loadDashboard();
      loadDropdownData();
      showToast('Login berhasil! Selamat datang, ' + currentUser.fullname);
    } else {
      errMsg.innerText = res.error;
      errMsg.style.display = 'block';
    }
  }).withFailureHandler(function(err) {
    showLoading(false);
    errMsg.innerText = "Error: " + err.toString();
    errMsg.style.display = 'block';
  }).loginUser(user, pass);
}

function handleLogout() {
  sessionStorage.removeItem('currentUser');
  currentUser = {};
  document.getElementById('login-page').style.display = 'flex';
  document.getElementById('login-username').value = '';
  document.getElementById('login-password').value = '';
  document.getElementById('login-error-message').style.display = 'none';
  renderDemoChips();
  showToast('Logout berhasil.');
}

function updateHeaderProfile() {
  document.getElementById('header-user-name').innerText = currentUser.fullname;
  document.getElementById('header-user-role').innerText = currentUser.role;
  document.getElementById('header-user-avatar').innerText = currentUser.fullname.split(' ').map(n => n[0]).join('');

  // Show/hide Admin menus
  const isAdmin = currentUser && currentUser.role === 'Administrator';
  const userMenu = document.querySelector('.menu-item[data-view="master-user"]');
  const matrixMenu = document.querySelector('.menu-item[data-view="matrix"]');
  if (userMenu) userMenu.style.display = isAdmin ? 'flex' : 'none';
  if (matrixMenu) matrixMenu.style.display = isAdmin ? 'flex' : 'none';
}

/**
 * SINGLE PAGE APPLICATION NAVIGATION
 */
function setupNavigation() {
  const menuItems = document.querySelectorAll('.menu-item');
  menuItems.forEach(item => {
    item.addEventListener('click', function(e) {
      e.preventDefault();
      
      const targetView = this.getAttribute('data-view');
      
      // Protect Admin views
      const isAdmin = currentUser && currentUser.role === 'Administrator';
      if ((targetView === 'master-user' || targetView === 'matrix') && !isAdmin) {
        showToast('Akses ditolak: Menu ini hanya untuk Administrator.', true);
        return;
      }

      // Remove active states from sidebar
      menuItems.forEach(m => m.classList.remove('active'));
      this.classList.add('active');
      
      // Switch view panels
      const views = document.querySelectorAll('.page-view');
      views.forEach(v => v.classList.remove('active'));

      
      const targetPanel = document.getElementById('view-' + targetView);
      if (targetPanel) {
        targetPanel.classList.add('active');
        
        // Trigger specific loaders
        if (targetView === 'dashboard') loadDashboard();
        else if (targetView === 'pr-new') resetPRForm();
        else if (targetView === 'pd-new') resetPDForm();
        else if (targetView === 'approval') loadApprovalCenter();
        else if (targetView === 'history') loadHistoryCenter();
        else if (targetView === 'budget') { loadBudgetDashboard(); loadBudgetTahunan(); }
        else if (targetView === 'pdf-archive') initPDFArchivePage();
        else if (targetView === 'audit') loadAuditTrail();
        else if (targetView === 'master-dept' || targetView === 'master-coa' || targetView === 'master-user' || targetView === 'matrix') loadMasterDataTables(targetView);
      }
    });
  });
}

/**
 * FORM HANDLING: PURCHASE REQUEST & PENGAJUAN DANA
 */
function setupFormHandlers() {
  // PR Add Item row trigger
  document.getElementById('btn-pr-add-item').addEventListener('click', addPRItemRow);
  
  // PR Form Submit
  document.getElementById('pr-form').addEventListener('submit', function(e) {
    e.preventDefault();
    submitPRDocument();
  });
  
  // PD Form Submit
  document.getElementById('pd-form').addEventListener('submit', function(e) {
    e.preventDefault();
    submitPDDocument();
  });
}

function addPRItemRow() {
  const tbody = document.getElementById('pr-items-tbody');
  const rowCount = tbody.rows.length + 1;
  const tr = document.createElement('tr');
  
  // Populate options for COA select
  let coaOptions = dropdownData.coas ? dropdownData.coas.map(c => `<option value="${c.Code}">${c.Code} - ${c.Name}</option>`).join('') : '';
  let ceOptions = dropdownData.costElements ? dropdownData.costElements.map(e => `<option value="${e.Code}">${e.Code} - ${e.Name}</option>`).join('') : '';
  
  tr.innerHTML = `
    <td>${rowCount}</td>
    <td>
      <select class="form-coa" required onchange="onCOAChange(this)">
        <option value="">Select COA</option>
        ${coaOptions}
      </select>
    </td>
    <td><input type="text" class="form-part" placeholder="Part Number"></td>
    <td><input type="text" class="form-desc" placeholder="Description" required></td>
    <td>
      <select class="form-ce">
        <option value="">Select Element</option>
        ${ceOptions}
      </select>
    </td>
    <td><input type="number" class="form-qty" value="1" min="1" required oninput="calculateRowTotal(this)"></td>
    <td><input type="text" class="form-uom" value="Unit" required></td>
    <td><input type="number" class="form-price" value="0" min="0" required oninput="calculateRowTotal(this)"></td>
    <td class="row-total-val" style="font-weight: 700;">Rp 0</td>
    <td>
      <button type="button" class="action-icon-btn" onclick="removePRItemRow(this)">
        <i class="fas fa-trash"></i>
      </button>
    </td>
  `;
  tbody.appendChild(tr);
}

function removePRItemRow(btn) {
  const row = btn.closest('tr');
  row.remove();
  reindexPRRows();
  calculateGrandTotal();
}

function reindexPRRows() {
  const tbody = document.getElementById('pr-items-tbody');
  Array.from(tbody.rows).forEach((row, idx) => {
    row.cells[0].innerText = idx + 1;
  });
}

function onCOAChange(select) {
  const row = select.closest('tr');
  const code = select.value;
  const matched = dropdownData.coas ? dropdownData.coas.find(c => c.Code === code) : null;
  if (matched) {
    row.querySelector('.form-desc').value = matched.Name;
  }
}

function calculateRowTotal(input) {
  const row = input.closest('tr');
  const qty = parseFloat(row.querySelector('.form-qty').value) || 0;
  const price = parseFloat(row.querySelector('.form-price').value) || 0;
  const total = qty * price;
  row.querySelector('.row-total-val').innerText = formatRupiah(total);
  calculateGrandTotal();
}

function calculateGrandTotal() {
  let grandTotal = 0;
  const rows = document.querySelectorAll('#pr-items-tbody tr');
  rows.forEach(row => {
    const qty = parseFloat(row.querySelector('.form-qty').value) || 0;
    const price = parseFloat(row.querySelector('.form-price').value) || 0;
    grandTotal += qty * price;
  });
  
  document.getElementById('pr-grand-total').innerText = formatRupiah(grandTotal);
}

function resetPRForm() {
  document.getElementById('pr-form').reset();
  document.getElementById('pr-items-tbody').innerHTML = '';
  document.getElementById('pr-grand-total').innerText = 'Rp 0';
  document.getElementById('pr-date').value = new Date().toISOString().substring(0, 10);
  
  // Set requester to current user
  document.getElementById('pr-requester').value = currentUser.fullname;
  document.getElementById('pr-department').value = currentUser.department;
  
  // Add initial row
  addPRItemRow();
}

function getFileData(input) {
  return new Promise((resolve) => {
    const file = input && input.files ? input.files[0] : null;
    if (!file) {
      resolve({ data: '', name: '' });
      return;
    }
    const reader = new FileReader();
    reader.onload = function(e) {
      resolve({ data: e.target.result, name: file.name });
    };
    reader.readAsDataURL(file);
  });
}

function submitPRDocument() {
  const rows = document.querySelectorAll('#pr-items-tbody tr');
  if (rows.length === 0) {
    alert("Please add at least one line item.");
    return;
  }
  
  const attachmentInput = document.getElementById('pr-attachment-file');
  getFileData(attachmentInput).then(fileInfo => {
    const metadata = {
      type: 'PR',
      date: document.getElementById('pr-date').value,
      department: document.getElementById('pr-department').value,
      priority: document.getElementById('pr-priority').value,
      inventoryType: document.getElementById('pr-inventory-type').value,
      purchaseCategory: document.getElementById('pr-category').value,
      subject: document.getElementById('pr-subject').value,
      requester: currentUser.fullname,
      userFor: document.getElementById('pr-user-for').value,
      attachment: fileInfo.data,
      attachmentName: fileInfo.name,
      budgetCapture: ''
    };
    
    const items = [];
    rows.forEach(row => {
      items.push({
        coa: row.querySelector('.form-coa').value,
        partNumber: row.querySelector('.form-part').value,
        description: row.querySelector('.form-desc').value,
        costElement: row.querySelector('.form-ce').value,
        quantity: row.querySelector('.form-qty').value,
        uom: row.querySelector('.form-uom').value,
        price: row.querySelector('.form-price').value
      });
    });
    
    showLoading(true);
    google.script.run.withSuccessHandler(function(res) {
      showLoading(true); // Keep loading visible while page redirects/updates
      google.script.run.withSuccessHandler(function(data) {
        showLoading(false);
        if (res.success) {
          showToast('PR Submitted Successfully: ' + res.docNumber);
          resetPRForm();
          // Clear file input
          if (attachmentInput) attachmentInput.value = '';
          
          // Refresh dashboard data
          loadDashboardData(data);
          document.querySelector('[data-view="dashboard"]').click(); // Return to dashboard
        } else {
          alert("Submission Error: " + res.error);
        }
      }).withFailureHandler(function(err) {
        showLoading(false);
        alert("Refresh Error: " + err.toString());
      }).getDashboardData();
    }).withFailureHandler(function(err) {
      showLoading(false);
      alert("Script Error: " + err.toString());
    }).submitRequest(metadata, items);
  });
}

// PD Form submission
function resetPDForm() {
  document.getElementById('pd-form').reset();
  document.getElementById('pd-date').value = new Date().toISOString().substring(0, 10);
  document.getElementById('pd-requester').value = currentUser.fullname;
  document.getElementById('pd-department').value = currentUser.department;
  
  // Fetch suggested PD document number from server
  google.script.run.withSuccessHandler(function(suggestedNo) {
    document.getElementById('pd-doc-no').value = suggestedNo;
  }).getSuggestedPDNumber(currentUser.department);
  
  const previewContainer = document.getElementById('pd-budget-capture-preview-container');
  if (previewContainer) previewContainer.style.display = 'none';
  const previewImg = document.getElementById('pd-budget-capture-preview');
  if (previewImg) previewImg.src = '';
}

function submitPDDocument() {
  const attachmentInput = document.getElementById('pd-attachment-file');
  const budgetCaptureInput = document.getElementById('pd-budget-capture-file');
  
  Promise.all([getFileData(attachmentInput), getFileData(budgetCaptureInput)]).then(filesInfo => {
    const attachmentFile = filesInfo[0];
    const budgetCaptureFile = filesInfo[1];
    
    const metadata = {
      type: 'PD',
      docNumber: document.getElementById('pd-doc-no').value,
      date: document.getElementById('pd-date').value,
      department: document.getElementById('pd-department').value,
      priority: document.getElementById('pd-priority').value,
      subject: document.getElementById('pd-subject').value,
      requester: currentUser.fullname,
      userFor: document.getElementById('pd-user-for').value,
      attachment: attachmentFile.data,
      attachmentName: attachmentFile.name,
      budgetCapture: budgetCaptureFile.data
    };
    
    const items = [{
      coa: 'PD-COA',
      description: document.getElementById('pd-subject').value,
      quantity: 1,
      uom: 'Lot',
      price: document.getElementById('pd-nominal').value
    }];
    
    showLoading(true);
    google.script.run.withSuccessHandler(function(res) {
      showLoading(true);
      google.script.run.withSuccessHandler(function(data) {
        showLoading(false);
        if (res.success) {
          showToast('PD Submitted Successfully: ' + res.docNumber);
          resetPDForm();
          if (attachmentInput) attachmentInput.value = '';
          if (budgetCaptureInput) budgetCaptureInput.value = '';
          
          loadDashboardData(data);
          document.querySelector('[data-view="dashboard"]').click();
        } else {
          alert("Submission Error: " + res.error);
        }
      }).withFailureHandler(function(err) {
        showLoading(false);
        alert("Refresh Error: " + err.toString());
      }).getDashboardData();
    }).withFailureHandler(function(err) {
      showLoading(false);
      alert("Script Error: " + err.toString());
    }).submitRequest(metadata, items);
  });
}

/**
 * DASHBOARD VIEW LOADER
 */
function loadDashboard() {
  showLoading(true);
  google.script.run.withSuccessHandler(function(data) {
    showLoading(false);
    
    // KPI Values
    document.getElementById('kpi-total-pd').innerText = formatRupiah(data.kpis.totalPD);
    document.getElementById('kpi-count-pd').innerText = data.kpis.countPD + " Dokumen";
    document.getElementById('kpi-total-pr').innerText = formatRupiah(data.kpis.totalPR);
    document.getElementById('kpi-count-pr').innerText = data.kpis.countPR + " Dokumen";
    
    document.getElementById('kpi-pending').innerText = data.kpis.pendingCount;
    document.getElementById('kpi-approved').innerText = data.kpis.approvedCount;
    document.getElementById('kpi-rejected').innerText = data.kpis.rejectedCount;
    document.getElementById('kpi-budget-avail').innerText = formatRupiah(data.kpis.budgetAvailable);
    document.getElementById('kpi-budget-total').innerText = "dari " + formatRupiah(data.kpis.totalBudgetLimit);
    
    // Mini progress counters
    document.getElementById('count-head').innerText = data.approvalProgress.headDept + " Pending";
    document.getElementById('count-pm').innerText = data.approvalProgress.projectManager + " Pending";
    document.getElementById('count-finance').innerText = data.approvalProgress.finance + " Pending";
    document.getElementById('count-cc').innerText = data.approvalProgress.costControl + " Pending";
    document.getElementById('count-gm').innerText = data.approvalProgress.gmCfo + " Pending";
    
    // Department Overview Grid
    renderDepartmentOverview(data.deptOverview);
    
    // Recent Activities Table
    renderRecentActivities(data.recentActivities);
    
    // Notifications list
    renderNotificationsList(data.notifications);
    
    // Render Dashboard Charts
    renderDashboardCharts(data.charts, data.kpis.budgetUtilPercent);
    
  }).withFailureHandler(function(err) {
    showLoading(false);
    console.error("Dashboard error: ", err);
  }).getDashboardData();
}

function renderDepartmentOverview(list) {
  const container = document.getElementById('dept-overview-grid');
  container.innerHTML = '';
  list.forEach(dept => {
    const card = document.createElement('div');
    card.className = 'dept-mini-card';
    card.innerHTML = `
      <div class="dept-mini-name">${dept.dept}</div>
      <div class="dept-mini-count">PD: ${dept.pdCount} | PR: ${dept.prCount}</div>
      <div class="dept-mini-budget">${formatRupiah(dept.budget)}</div>
    `;
    container.appendChild(card);
  });
}

function renderRecentActivities(activities) {
  const tbody = document.getElementById('recent-activities-tbody');
  tbody.innerHTML = '';
  if (activities.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;">No recent activities</td></tr>`;
    return;
  }
  
  activities.forEach((act, idx) => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${idx + 1}</td>
      <td><span class="status-pill ${act.type.toLowerCase() === 'pr' ? 'pending' : 'approved'}">${act.type}</span></td>
      <td>${act.docNumber}</td>
      <td>${act.subject}</td>
      <td>${act.requester}</td>
      <td><span class="status-pill ${act.status.toLowerCase()}">${act.status}</span></td>
      <td>${act.date}</td>
    `;
    tbody.appendChild(tr);
  });
}

function renderNotificationsList(logs) {
  // 1. Dashboard panel
  const container = document.getElementById('notif-list-container');
  if (container) {
    container.innerHTML = '';
    if (!logs || logs.length === 0) {
      container.innerHTML = '<div style="padding: 15px; color: var(--text-secondary); text-align: center; font-size: 11px;">Belum ada notifikasi</div>';
    } else {
      logs.forEach(log => {
        const div = document.createElement('div');
        div.className = 'notif-row';
        div.innerHTML = `
          <div class="notif-icon"><i class="fas fa-bell"></i></div>
          <div class="notif-details">
            <div class="notif-title"><strong>${log.user}</strong> ${log.activity} (${log.docNumber})</div>
            <div class="notif-time">${log.timeAgo}</div>
          </div>
        `;
        container.appendChild(div);
      });
    }
  }

  // 2. Bell Dropdown list
  const dropdownList = document.getElementById('notif-dropdown-list');
  if (dropdownList) {
    dropdownList.innerHTML = '';
    if (!logs || logs.length === 0) {
      dropdownList.innerHTML = '<div style="padding: 16px; color: var(--text-secondary); text-align: center; font-size: 11px;">Belum ada notifikasi</div>';
    } else {
      logs.forEach(log => {
        const div = document.createElement('div');
        div.style.display = 'flex';
        div.style.gap = '10px';
        div.style.padding = '8px 16px';
        div.style.borderBottom = '1px solid var(--border-color)';
        div.style.alignItems = 'flex-start';
        div.innerHTML = `
          <div style="background: var(--bg-hover); color: var(--accent-orange); width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; flex-shrink: 0; margin-top: 2px;">
            <i class="fas fa-bell"></i>
          </div>
          <div style="flex-grow: 1; min-width: 0;">
            <div style="font-size: 11px; color: var(--text-primary); line-height: 1.4; word-wrap: break-word;">
              <strong>${log.user}</strong> ${log.activity}
              <div style="font-family: monospace; font-size: 10px; color: var(--accent-cyan); display: inline-block; margin-top: 1px;">${log.docNumber}</div>
            </div>
            <div style="font-size: 9px; color: var(--text-secondary); margin-top: 2px;">${log.timeAgo}</div>
          </div>
        `;
        dropdownList.appendChild(div);
      });
    }
  }

  // 3. Badges and Counts
  const badge = document.getElementById('notif-badge');
  const unreadCount = document.getElementById('notif-unread-count');
  
  const count = logs ? logs.length : 0;
  if (count > 0) {
    if (badge) badge.style.display = 'block';
    if (unreadCount) {
      unreadCount.textContent = count > 9 ? '9+' : count;
      unreadCount.style.display = 'inline-block';
    }
  } else {
    if (badge) badge.style.display = 'none';
    if (unreadCount) unreadCount.style.display = 'none';
  }
}


/**
 * CHARTS HANDLERS (Chart.js Integration)
 */
function renderDashboardCharts(chartData, budgetUtilPercent) {
  // 1. Monthly PD vs PR Line Chart
  if (charts.monthly) charts.monthly.destroy();
  const ctxMonthly = document.getElementById('chart-monthly').getContext('2d');
  charts.monthly = new Chart(ctxMonthly, {
    type: 'line',
    data: {
      labels: chartData.labels,
      datasets: [
        {
          label: 'PD',
          data: chartData.pdData,
          borderColor: '#00e5ff',
          backgroundColor: 'rgba(0, 229, 255, 0.1)',
          fill: true,
          tension: 0.4
        },
        {
          label: 'PR',
          data: chartData.prData,
          borderColor: '#ffb300',
          backgroundColor: 'rgba(255, 179, 0, 0.1)',
          fill: true,
          tension: 0.4
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: '#f3f4f6' } }
      },
      scales: {
        x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#9ca3af' } },
        y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#9ca3af' } }
      }
    }
  });

  // 2. Department pie
  if (charts.dept) charts.dept.destroy();
  const ctxDept = document.getElementById('chart-dept').getContext('2d');
  charts.dept = new Chart(ctxDept, {
    type: 'doughnut',
    data: {
      labels: chartData.deptLabels,
      datasets: [{
        data: chartData.deptData,
        backgroundColor: ['#00e5ff', '#ffb300', '#2979ff', '#00e676', '#ff1744', '#d500f9', '#9ca3af']
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'right', labels: { color: '#f3f4f6', boxWidth: 12 } }
      }
    }
  });

  // 3. Budget utilization gauge
  if (charts.util) charts.util.destroy();
  const ctxUtil = document.getElementById('chart-util').getContext('2d');
  charts.util = new Chart(ctxUtil, {
    type: 'doughnut',
    data: {
      labels: ['Used', 'Available'],
      datasets: [{
        data: [budgetUtilPercent, 100 - budgetUtilPercent],
        backgroundColor: ['#00e676', 'rgba(255,255,255,0.1)'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      cutout: '80%',
      rotation: 270,
      circumference: 180,
      plugins: {
        legend: { display: false }
      }
    }
  });
  
  // Set percentage label overlay
  document.getElementById('chart-util-label').innerText = budgetUtilPercent + "%";
}

/**
 * APPROVAL CENTER LOGIC
 */
function loadApprovalCenter() {
  // Update Tab active headers
  const tabs = document.querySelectorAll('#approval-tabs .tab-item');
  tabs.forEach(t => {
    t.classList.remove('active');
    if (t.getAttribute('data-role') === currentUser.role) {
      t.classList.add('active');
    }
  });
  
  showLoading(true);
  google.script.run.withSuccessHandler(function(list) {
    showLoading(false);
    renderApprovalList(list);
  }).withFailureHandler(function(err) {
    showLoading(false);
    alert(err.toString());
  }).getApprovalRequests(currentUser.role);
}

function renderApprovalList(list) {
  const tbody = document.getElementById('approval-center-tbody');
  tbody.innerHTML = '';
  if (list.length === 0) {
    tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;">No pending approval requests for role ${currentUser.role}</td></tr>`;
    return;
  }
  
  list.forEach((req, idx) => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${idx + 1}</td>
      <td><span class="status-pill ${req.type.toLowerCase() === 'pr' ? 'pending' : 'approved'}">${req.type}</span></td>
      <td>${req.docNumber}</td>
      <td>${req.subject}</td>
      <td>${req.requester}</td>
      <td>${req.date}</td>
      <td style="font-weight:700; color: var(--accent-cyan);">${formatRupiah(req.nominal)}</td>
      <td><span class="status-pill pending">Pending</span></td>
      <td>
        <button class="form-btn submit" style="padding: 4px 10px;" onclick="openApprovalModal('${req.id}')">Review</button>
      </td>
    `;
    tbody.appendChild(tr);
  });
}

function openApprovalModal(requestId) {
  showLoading(true);
  google.script.run.withSuccessHandler(function(doc) {
    showLoading(false);
    if (!doc) return;
    activeReviewDoc = doc;
    
    // Set Details metadata
    document.getElementById('modal-doc-number').innerText = doc.metadata.docNumber + " (" + doc.metadata.type + ")";
    document.getElementById('modal-requester').innerText = doc.metadata.requester + " / " + doc.metadata.department;
    document.getElementById('modal-date').innerText = doc.metadata.date + " | Priority: " + doc.metadata.priority;
    document.getElementById('modal-subject').innerText = doc.metadata.subject;
    document.getElementById('modal-user-for').innerText = doc.metadata.userFor || '-';
    
    const userForContainer = document.getElementById('modal-user-for-container');
    if (userForContainer) {
      userForContainer.style.display = doc.metadata.type === 'PD' ? 'none' : 'block';
    }
    
    // Render lines table
    const tbody = document.getElementById('modal-items-tbody');
    tbody.innerHTML = '';
    doc.items.forEach((item, idx) => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${idx + 1}</td>
        <td>${item.COA}</td>
        <td>${item.PartNumber || '-'}</td>
        <td>${item.Description}</td>
        <td>${item.CostElement || '-'}</td>
        <td>${item.Quantity}</td>
        <td>${item.UoM}</td>
        <td>${formatRupiah(item.Price)}</td>
        <td style="font-weight:700;">${formatRupiah(item.Total)}</td>
      `;
      tbody.appendChild(tr);
    });
    
    document.getElementById('modal-grand-total').innerText = formatRupiah(doc.metadata.nominal);
    
    // Render workflow signatures signatures boxes
    renderSignatureBoxes(doc.signatures, doc.metadata.nominal, doc.metadata.type, doc.metadata.department);
    
    // Show Modal
    document.getElementById('approval-modal').classList.add('active');
    
    // Store request ID in the buttons
    document.getElementById('btn-modal-approve').setAttribute('data-id', requestId);
    document.getElementById('btn-modal-reject').setAttribute('data-id', requestId);
    
  }).withFailureHandler(function(err) {
    showLoading(false);
    alert(err.toString());
  }).getRequestDetails(requestId);
}

// Procedural Elegant Electronic Signature Generator (Procedural curves lines SVG)
function generateProceduralSignature(name) {
  if (!name) return '';
  // Convert name initials/parts to deterministic random path offsets
  let hash = 0;
  for (let i = 0; i < name.length; i++) {
    hash = name.charCodeAt(i) + ((hash << 5) - hash);
  }
  
  const getOffset = (seed, scale) => {
    return Math.sin(seed + hash) * scale;
  };
  
  // Starting curves path
  let path = `M 15,${25 + getOffset(1, 4)} `;
  path += `Q 35,${12 + getOffset(2, 6)} 50,${25 + getOffset(3, 4)} `;
  path += `T 85,${20 + getOffset(4, 5)} `;
  path += `Q 105,${38 + getOffset(5, 5)} 120,${22 + getOffset(6, 4)} `;
  
  // Elegant underscore loop loop
  path += `M 10,${30 + getOffset(7, 3)} `;
  path += `C 50,${45 + getOffset(8, 2)} 100,${40 + getOffset(9, 2)} 135,${32 + getOffset(10, 3)}`;
  
  return `
    <svg class="svg-signature" viewBox="0 0 150 50">
      <path d="${path}" />
      <text x="35" y="46" font-family="'Outfit', sans-serif" font-size="8" fill="#6b7280" opacity="0.6">e-Signed by ${name}</text>
    </svg>
  `;
}

function renderSignatureBoxes(sigs, nominal, docType, department) {
  const container = document.getElementById('modal-signatures-row');
  container.innerHTML = '';
  
  // Define required signers based on amount matrix
  const steps = getLocalApprovalSteps(docType, department, nominal);
  
  // Render Dibuat Oleh (User) first
  container.appendChild(createSignatureBoxHTML('Dibuat Oleh', sigs.user, true));
  
  // Add other stages
  steps.forEach(step => {
    let mappingKey;
    let displayTitle = step;
    if (docType === 'PD') {
      const mapping = {
        'Project Manager': 'deptHeadPm',
        'Finance': 'financeSite'
      };
      mappingKey = mapping[step];
      if (step === 'Project Manager') displayTitle = 'Dept Head / PM';
      if (step === 'Finance') displayTitle = 'Finance Site';
    } else {
      const mapping = {
        'Supervisor': 'supervisor',
        'Finance': 'finance',
        'Project Manager': 'projectManager'
      };
      mappingKey = mapping[step];
    }
    
    container.appendChild(createSignatureBoxHTML(displayTitle, sigs[mappingKey], false));
  });
}

function createSignatureBoxHTML(title, sigObj, isRequester) {
  const div = document.createElement('div');
  div.className = 'signature-box';
  
  let sigArea = '';
  let statusText = title.toUpperCase();
  let dateText = '';
  let signerName = '-';
  
  if (sigObj && sigObj.status === 'SUBMITTED') {
    if (sigObj.signatureText && sigObj.signatureText.indexOf('data:image') === 0) {
      sigArea = `<div class="signature-area"><img src="${sigObj.signatureText}" style="max-height:45px; max-width:140px; object-fit:contain;" /></div>`;
    } else {
      sigArea = `<div class="signature-area text-sign">${sigObj.name}</div>`;
    }
    signerName = sigObj.name;
    dateText = new Date(sigObj.date).toLocaleDateString();
  } else if (sigObj && sigObj.status === 'APPROVED') {
    if (sigObj.signatureText && sigObj.signatureText.indexOf('data:image') === 0) {
      sigArea = `<div class="signature-area"><img src="${sigObj.signatureText}" style="max-height:45px; max-width:140px; object-fit:contain;" /></div>`;
    } else {
      sigArea = `<div class="signature-area">${generateProceduralSignature(sigObj.name)}</div>`;
    }
    signerName = sigObj.name;
    dateText = new Date(sigObj.date).toLocaleDateString() + ' ' + new Date(sigObj.date).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
  } else if (sigObj && sigObj.status === 'REJECTED') {
    sigArea = `<div class="signature-area pending-sign" style="color:var(--accent-red); background:rgba(255,23,68,0.05); border-color:var(--accent-red);">REJECTED</div>`;
    signerName = sigObj.name;
    dateText = new Date(sigObj.date).toLocaleDateString();
  } else {
    sigArea = `<div class="signature-area pending-sign">PENDING</div>`;
  }
  
  div.innerHTML = `
    <div class="signature-title">${title}</div>
    ${sigArea}
    <div>
      <div class="signature-name">${signerName}</div>
      <div class="signature-date">${dateText}</div>
    </div>
  `;
  return div;
}

function getLocalApprovalSteps(docType, department, amount) {
  if (!dropdownData || !dropdownData.matrix) {
    return docType === 'PD' ? ["Project Manager", "Finance"] : ["Supervisor", "Finance", "Project Manager"];
  }
  const matched = dropdownData.matrix.filter(m => {
    const isDocTypeMatch = m.DocType === docType;
    const isDeptMatch = m.Department === 'ALL' || m.Department === department;
    const min = parseFloat(m.MinAmount) || 0;
    const max = parseFloat(m.MaxAmount) || Infinity;
    const isAmountMatch = amount >= min && amount <= max;
    return isDocTypeMatch && isDeptMatch && isAmountMatch;
  });
  matched.sort((a, b) => {
    if (a.Department !== 'ALL' && b.Department === 'ALL') return -1;
    if (a.Department === 'ALL' && b.Department !== 'ALL') return 1;
    return 0;
  });
  if (matched.length > 0) {
    return matched[0].Steps.split(',').map(s => s.trim());
  }
  return docType === 'PD' ? ["Project Manager", "Finance"] : ["Supervisor", "Finance", "Project Manager"];
}

function closeApprovalModal() {
  document.getElementById('approval-modal').classList.remove('active');
}

function executeApproval(action) {
  const id = document.getElementById('btn-modal-' + (action === 'APPROVE' ? 'approve' : 'reject')).getAttribute('data-id');
  let comment = '';
  
  if (action === 'REJECT') {
    comment = prompt("Please enter rejection reason/comment:");
    if (comment === null) return; // Cancelled
    if (comment.trim() === '') {
      alert("Rejection reason is required.");
      return;
    }
  }
  
  showLoading(true);
  google.script.run.withSuccessHandler(function(res) {
    showLoading(false);
    if (res.success) {
      showToast('Document ' + (action === 'APPROVE' ? 'Approved' : 'Rejected') + ' successfully!');
      closeApprovalModal();
      loadApprovalCenter();
    } else {
      alert("Process failed: " + res.error);
    }
  }).withFailureHandler(function(err) {
    showLoading(false);
    alert(err.toString());
  }).processApproval(id, action, currentUser.role, comment, currentUser.fullname);
}

