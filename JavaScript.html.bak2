            </tr>
            <tr style="font-weight:bold; font-size:8px;">
              <td style="border:1px solid #111; padding:3px;">${sigPrepared.name}</td>
              <td style="border:1px solid #111; padding:3px;">${sigVerified.name}</td>
              <td style="border:1px solid #111; padding:3px;">${sigApprovedPm.name}</td>
              <td style="border:1px solid #111; padding:3px;">${sigCheckedFin.name}</td>
              <td style="border:1px solid #111; padding:3px;">${sigCheckedCc.name}</td>
              <td style="border:1px solid #111; padding:3px;">${sigCheckedAcc.name}</td>
              <td style="border:1px solid #111; padding:3px;">${sigDisbPm.name}</td>
              <td style="border:1px solid #111; padding:3px;">${sigDisbCfo.name}</td>
            </tr>
            <tr style="font-size:7.5px; color:#555; font-weight:normal; vertical-align:top;">
              <td style="border:1px solid #111; padding:3px;">USER</td>
              <td style="border:1px solid #111; padding:3px;">Dept. Head Department<br>/ Project Manager</td>
              <td style="border:1px solid #111; padding:3px;">Project Manager /<br>Operation Manager</td>
              <td style="border:1px solid #111; padding:3px;">Finance Site</td>
              <td style="border:1px solid #111; padding:3px;">Cost Control</td>
              <td style="border:1px solid #111; padding:3px;">Accounting HO</td>
              <td style="border:1px solid #111; padding:3px;">Project Manager /<br>GM Operation / COO</td>
              <td style="border:1px solid #111; padding:3px;">GM FAT / CFO</td>
            </tr>
          </tbody>
        </table>
        
        <!-- Approval Matrix -->
        <table style="width:100%; border-collapse:collapse; text-align:center; font-size:8.5px; border:1px solid #111; table-layout:fixed; margin-top:15px;">
          <thead>
            <tr style="font-weight:bold;">
              <th style="border:1px solid #111; padding:3px; background:#ccc; font-style:italic; width:25%;">Matriks Persetujuan</th>
              <th style="border:1px solid #111; padding:3px; width:25%;">Diajukan</th>
              <th style="border:1px solid #111; padding:3px; width:25%;">Disetujui</th>
              <th style="border:1px solid #111; padding:3px; width:25%;">Persetujuan Pencairan</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td style="border:1px solid #111; padding:3px; font-weight:bold;">&le; 5 Juta Rupiah</td>
              <td style="border:1px solid #111; padding:3px;">User (Supervisor)</td>
              <td style="border:1px solid #111; padding:3px;">Dept. Head</td>
              <td style="border:1px solid #111; padding:3px;">PM / Manager</td>
            </tr>
            <tr>
              <td style="border:1px solid #111; padding:3px; font-weight:bold;">&gt; 5 Jt - 44 Jt Rupiah</td>
              <td style="border:1px solid #111; padding:3px;">Dept Head</td>
              <td style="border:1px solid #111; padding:3px;">PM / Manager</td>
              <td style="border:1px solid #111; padding:3px;">Board of Executive</td>
            </tr>
            <tr>
              <td style="border:1px solid #111; padding:3px; font-weight:bold;">&gt; 45 jt - &le; 100 jt</td>
              <td style="border:1px solid #111; padding:3px;">PM/ Manager</td>
              <td style="border:1px solid #111; padding:3px;">GM</td>
              <td style="border:1px solid #111; padding:3px;">BOE & GM FAT</td>
            </tr>
            <tr>
              <td style="border:1px solid #111; padding:3px; font-weight:bold;">&gt; 100 jt</td>
              <td style="border:1px solid #111; padding:3px;">Manager / GM</td>
              <td style="border:1px solid #111; padding:3px;">BOE</td>
              <td style="border:1px solid #111; padding:3px;">GM FAT / CFO</td>
            </tr>
          </tbody>
        </table>
        
        ${doc.budgetCapture ? `
          <div style="border:1px solid #111; padding:8px; margin-top:12px; page-break-inside:avoid;">
            <div style="font-weight:bold; font-size:10px; border-bottom:1px solid #111; padding-bottom:3px; margin-bottom:5px; text-transform:uppercase;">Capture Budget / Bukti Budget:</div>
            <div style="text-align:center;"><img src="${doc.budgetCapture}" style="max-height:280px; max-width:100%; object-fit:contain;" /></div>
          </div>
        ` : ''}
        
        ${doc.attachment ? `
          <div class="page-break-preview" style="border:1px solid #111; padding:8px; margin-top:20px;">
            <div style="font-weight:bold; font-size:10px; border-bottom:1px solid #111; padding-bottom:3px; margin-bottom:5px; text-transform:uppercase;">Lampiran / Attachments:</div>
            ${doc.attachment.indexOf('data:application/pdf') === 0 || doc.attachment.toLowerCase().indexOf('.pdf') !== -1 || (doc.attachmentName && doc.attachmentName.toLowerCase().indexOf('.pdf') !== -1) ? 
              (doc.attachment.indexOf('data:application/pdf') === 0 ? 
                `<div class="pdf-rendering-container" data-pdf="${doc.attachment}" style="text-align:center; padding:10px;">Mengurai halaman PDF...</div>` :
                `<div style="padding:10px;"><a href="${doc.attachment}" target="_blank" style="color:#1565c0; text-decoration:underline; font-weight:bold;"><i class="fas fa-external-link-alt"></i> Buka Lampiran PDF (${doc.attachmentName || 'File'})</a></div>`
              ) :
              (doc.attachment.indexOf('data:image') === 0 || doc.attachment.match(/\.(jpeg|jpg|gif|png|webp|svg)/i) || (doc.attachmentName && doc.attachmentName.match(/\.(jpeg|jpg|gif|png|webp|svg)/i)) ? 
                `<div style="text-align:center;"><img src="${doc.attachment}" style="max-height:280px; max-width:100%; object-fit:contain;" /></div>` : 
                `<div style="padding:10px;"><a href="${doc.attachment}" target="_blank" download="${doc.attachmentName || 'lampiran'}" style="color:#1565c0; text-decoration:underline; font-weight:bold;">Unduh Lampiran (${doc.attachmentName || 'File'})</a></div>`
              )
            }
          </div>
        ` : ''}
      </div>
    `;
  }
}

function triggerPDFGeneration() {
  if (!activeReviewDoc) return;
  
  const doc = {
    type: activeReviewDoc.metadata.type,
    docNumber: activeReviewDoc.metadata.docNumber,
    date: activeReviewDoc.metadata.date,
    dept: activeReviewDoc.metadata.department,
    priority: activeReviewDoc.metadata.priority,
    inventoryType: activeReviewDoc.metadata.inventoryType,
    purchaseCategory: activeReviewDoc.metadata.purchaseCategory,
    subject: activeReviewDoc.metadata.subject,
    requester: activeReviewDoc.metadata.requester,
    nominal: activeReviewDoc.metadata.nominal,
    userFor: activeReviewDoc.metadata.userFor,
    attachment: activeReviewDoc.metadata.attachment,
    attachmentName: activeReviewDoc.metadata.attachmentName,
    budgetCapture: activeReviewDoc.metadata.budgetCapture,
    items: activeReviewDoc.items,
    budget: activeReviewDoc.budget,
    sigs: activeReviewDoc.signatures
  };

  showLoading(true);
  
  const targetWidth = doc.type === 'PD' ? 1080 : 800;

  // Temporarily force body/html overflow and widths to prevent layout folding and clipping
  const origBodyOverflow = document.body.style.overflow;
  const origBodyOverflowX = document.body.style.overflowX;
  const origHtmlOverflow = document.documentElement.style.overflow;
  const origHtmlOverflowX = document.documentElement.style.overflowX;
  const origBodyWidth = document.body.style.width;
  const origBodyMinWidth = document.body.style.minWidth;
  const origHtmlWidth = document.documentElement.style.width;
  const origHtmlMinWidth = document.documentElement.style.minWidth;
  
  document.body.style.overflow = 'visible';
  document.body.style.overflowX = 'visible';
  document.documentElement.style.overflow = 'visible';
  document.documentElement.style.overflowX = 'visible';
  document.body.style.width = targetWidth + 'px';
  document.body.style.minWidth = targetWidth + 'px';
  document.documentElement.style.width = targetWidth + 'px';
  document.documentElement.style.minWidth = targetWidth + 'px';
  
  // Create a hidden parent wrapper at (0,0) with proper layout width to prevent content folding
  const wrapper = document.createElement('div');
  wrapper.style.position = 'absolute';
  wrapper.style.left = '0';
  wrapper.style.top = '0';
  wrapper.style.width = targetWidth + 'px';
  wrapper.style.height = 'auto';
  wrapper.style.overflow = 'visible';
  wrapper.style.zIndex = '-9999';
  wrapper.style.pointerEvents = 'none';
  
  // Create the clean container to be captured
  const container = document.createElement('div');
  container.style.width = targetWidth + 'px';
  container.style.background = '#fff';
  container.innerHTML = buildPaperHTML(doc);
  
  wrapper.appendChild(container);
  document.body.appendChild(wrapper);
  
  const orientation = doc.type === 'PD' ? 'landscape' : 'portrait';
  const opt = {
    margin:       [8, 8, 8, 8],
    filename:     doc.docNumber.replace(/\//g, '_') + '.pdf',
    image:        { type: 'jpeg', quality: 0.98 },
    html2canvas:  { 
      scale: 2, 
      useCORS: true, 
      scrollY: 0,
      width: targetWidth,
      windowWidth: targetWidth
    },
    jsPDF:        { unit: 'mm', format: 'a4', orientation: orientation }
  };
  
  const pdfContainers = container.querySelectorAll('.pdf-rendering-container');
  const promises = [];
  pdfContainers.forEach(c => {
    const base64 = c.getAttribute('data-pdf');
    if (base64) {
      promises.push(renderPDFToCanvases(base64, c));
    }
  });

  Promise.all(promises).then(() => {
    const hasAttachment = !!container.querySelector('.page-break-preview');
    if (doc.type === 'PD' && hasAttachment) {
      // Mixed orientation: Landscape Page 1 (PD Form) + Portrait Page 2+ (Attachments)
      const pdFormElement = container.querySelector('.pd-landscape');
      const attachmentContainer = container.querySelector('.page-break-preview');
      
      html2canvas(pdFormElement, {
        scale: 2,
        useCORS: true,
        width: 1080,
        windowWidth: 1080
      }).then(function(pdCanvas) {
        const jsPDFClass = (window.jspdf && window.jspdf.jsPDF) || window.jsPDF;
        const pdf = new jsPDFClass({
          orientation: 'landscape',
          unit: 'px',
          format: [1080, 762]
        });
        
        pdf.addImage(pdCanvas.toDataURL('image/jpeg', 0.95), 'JPEG', 0, 0, 1080, 762);
        
        const canvases = attachmentContainer.querySelectorAll('canvas');
        if (canvases.length > 0) {
          // PDF attachment pages (canvases generated from renderPDFToCanvases)
          canvases.forEach(function(canvas) {
            pdf.addPage([800, 1130], 'portrait');
            pdf.addImage(canvas.toDataURL('image/jpeg', 0.95), 'JPEG', 0, 0, 800, 1130);
          });
          
          pdf.save(opt.filename);
          cleanup();
        } else {
          // Image attachment. Render attachmentContainer using html2canvas as a portrait page
          attachmentContainer.style.width = '800px';
          attachmentContainer.style.margin = '0 auto';
          
          html2canvas(attachmentContainer, {
            scale: 2,
            useCORS: true,
            width: 800,
            windowWidth: 800
          }).then(function(attachCanvas) {
            pdf.addPage([800, 1130], 'portrait');
            pdf.addImage(attachCanvas.toDataURL('image/jpeg', 0.95), 'JPEG', 0, 0, 800, 1130);
            
            pdf.save(opt.filename);
            cleanup();
          }).catch(handlePdfError);
        }
      }).catch(handlePdfError);
    } else {
      // Standard html2pdf flow
      html2pdf().from(container).set(opt).save().then(() => {
        showLoading(false);
        restoreStyles();
        showToast('PDF berhasil diunduh: ' + opt.filename);
      }).catch(handlePdfError);
    }
    
    function cleanup() {
      showLoading(false);
      restoreStyles();
      showToast('PDF berhasil diunduh: ' + opt.filename);
    }
    
    function restoreStyles() {
      if (wrapper.parentNode) {
        wrapper.parentNode.removeChild(wrapper);
      }
      document.body.style.overflow = origBodyOverflow;
      document.body.style.overflowX = origBodyOverflowX;
      document.documentElement.style.overflow = origHtmlOverflow;
      document.documentElement.style.overflowX = origHtmlOverflowX;
      document.body.style.width = origBodyWidth;
      document.body.style.minWidth = origBodyMinWidth;
      document.documentElement.style.width = origHtmlWidth;
      document.documentElement.style.minWidth = origHtmlMinWidth;
    }
    
    function handlePdfError(err) {
      console.error(err);
      showLoading(false);
      restoreStyles();
      alert("Gagal memproses PDF: " + err.toString());
    }
  }).catch((err) => {
    console.error(err);
    showLoading(false);
    if (wrapper.parentNode) {
      wrapper.parentNode.removeChild(wrapper);
    }
    document.body.style.overflow = origBodyOverflow;
    document.body.style.overflowX = origBodyOverflowX;
    document.documentElement.style.overflow = origHtmlOverflow;
    document.documentElement.style.overflowX = origHtmlOverflowX;
    document.body.style.width = origBodyWidth;
    document.body.style.minWidth = origBodyMinWidth;
    document.documentElement.style.width = origHtmlWidth;
    document.documentElement.style.minWidth = origHtmlMinWidth;
    alert("Gagal memproses PDF: " + err.toString());
  });
}

function triggerODFDownload() {
  if (!activeReviewDoc) return;
  const doc = activeReviewDoc;
  const wsData = [];
  
  // Company Information
  wsData.push(["BARA INDAH SINERGI GROUP"]);
  wsData.push(["PT. BHUMI KARYA UTAMA"]);
  wsData.push([]);
  wsData.push([doc.metadata.type === 'PR' ? "FORMULIR PURCHASE REQUEST (PR)" : "FORMULIR PERMOHONAN DANA (PD)"]);
  wsData.push([]);
  
  // Header Metadata
  wsData.push(["No Dokumen:", doc.metadata.docNumber]);
  wsData.push(["Tanggal:", doc.metadata.date]);
  wsData.push(["Department:", doc.metadata.department]);
  wsData.push(["Subject:", doc.metadata.subject]);
  wsData.push(["Prioritas:", doc.metadata.priority]);
  wsData.push(["Kebutuhan Detail (User For):", doc.metadata.userFor || '-']);
  wsData.push([]);
  
  // Table Header & Rows
  if (doc.metadata.type === 'PR') {
    wsData.push(["NO", "COA", "Part Number", "Description", "Cost Element", "Quantity", "UoM", "Price", "Total"]);
    doc.items.forEach((it, idx) => {
      wsData.push([
        idx + 1,
        it.COA || '',
        it.PartNumber || '',
        it.Description || '',
        it.CostElement || '',
        it.Quantity || 0,
        it.UoM || 'Unit',
        it.Price || 0,
        it.Total || 0
      ]);
    });
    wsData.push([]);
    wsData.push(["Total Purchase Request:", "", "", "", "", "", "", "", doc.metadata.nominal]);
  } else {
    wsData.push(["NO", "PC (Project Code)", "DR (Distribution Rules)", "Description", "QTY", "Price", "Amount (IDR)", "Information"]);
    doc.items.forEach((it, idx) => {
      wsData.push([
        idx + 1,
        it.PC || it.COA || '',
        it.DR || it.CostElement || '',
        it.Description || '',
        it.Quantity || 1,
        it.Price || 0,
        it.Total || 0,
        it.Information || ''
      ]);
    });
    wsData.push([]);
    wsData.push(["Total Permohonan Dana:", "", "", "", "", "", doc.metadata.nominal]);
    wsData.push(["Terbilang:", terbilangLocal(doc.metadata.nominal)]);
  }
  
  wsData.push([]);
  
  // Signatures Status
  wsData.push(["Workflow Approval Signatures Status:"]);
  const steps = getLocalApprovalSteps(doc.metadata.type, doc.metadata.department, doc.metadata.nominal);
  const allSteps = [
    { label: 'Prepared By (USER)', name: doc.signatures.user ? doc.signatures.user.name : '-' }
  ];
  
  steps.forEach(s => {
    let mappingKey;
    let label = s;
    if (doc.metadata.type === 'PD') {
      const mapping = {
        'Project Manager': 'deptHeadPm',
        'Finance': 'financeSite'
      };
      mappingKey = mapping[s];
      if (s === 'Project Manager') label = 'Dept Head / PM';
      if (s === 'Finance') label = 'Finance Site';
    } else {
      const mapping = {
        'Supervisor': 'supervisor',
        'Finance': 'finance',
        'Project Manager': 'projectManager'
      };
      mappingKey = mapping[s];
    }
    const sig = doc.signatures[mappingKey] || {};
    allSteps.push({ label: label, name: sig.name || 'PENDING' });
  });
  
  allSteps.forEach(step => {
    wsData.push([step.label + ":", step.name]);
  });

  // Build SheetJS Workbook
  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet(wsData);
  
  // Styling column widths
  const wscols = [
    {wch: 25},
    {wch: 30},
    {wch: 25},
    {wch: 40},
    {wch: 15},
    {wch: 15},
    {wch: 15},
    {wch: 30}
  ];
  ws['!cols'] = wscols;

  XLSX.utils.book_append_sheet(wb, ws, doc.metadata.type + " Data");
  
  // Save Workbook
  XLSX.writeFile(wb, doc.metadata.docNumber.replace(/\//g, '_') + '.ods', { bookType: 'ods' });
  showToast('Dokumen ODF (.ods) berhasil diunduh.');
}

// Convert number to Indonesian words (Local version for client-side)
function terbilangLocal(num) {
  if (num === 0) return 'nol rupiah';
  const satuan = ['','satu','dua','tiga','empat','lima','enam','tujuh','delapan','sembilan',
    'sepuluh','sebelas','dua belas','tiga belas','empat belas','lima belas','enam belas',
    'tujuh belas','delapan belas','sembilan belas'];
  function group(n, suffix) {
    if (n === 0) return '';
    if (n < 20) return satuan[n] + (suffix ? ' ' + suffix : '') + ' ';
    if (n < 100) return satuan[Math.floor(n/10)] + ' puluh ' + (n%10 ? satuan[n%10]+' ' : '');
    
    let result = '';
    const r10 = Math.floor(n/10)%10, r1 = n%10, r100 = Math.floor(n/100);
    if(r100) {
      if (r100 === 1) result += 'seratus ';
      else result += satuan[r100] + ' ratus ';
    }
    if(r10 === 1) { result += satuan[10 + r1] + ' '; }
    else { if(r10) result += satuan[r10] + ' puluh '; if(r1) result += satuan[r1] + ' '; }
    return result + (suffix ? suffix + ' ' : '');
  }
  let n = Math.floor(num), result = '';
  const triliun = Math.floor(n / 1000000000000); n %= 1000000000000;
  const miliar = Math.floor(n / 1000000000); n %= 1000000000;
  const juta = Math.floor(n / 1000000); n %= 1000000;
  const ribu = Math.floor(n / 1000); n %= 1000;
  const sisa = n;
  if(triliun) result += group(triliun,'triliun');
  if(miliar) result += group(miliar,'miliar');
  if(juta) result += group(juta,'juta');
  if(ribu === 1) result += 'seribu '; else if(ribu) result += group(ribu,'ribu');
  if(sisa) result += group(sisa,'');
  return (result.trim() || 'nol') + ' rupiah';
}

// ==============================================
// ADMINISTRATOR ACTIONS & MODAL CONTROLLERS
// ==============================================

function openAddUserModal() {
  document.getElementById('user-modal-title').innerText = 'Tambah User Baru';
  document.getElementById('user-form-id').value = '';
  document.getElementById('user-form-fullname').value = '';
  document.getElementById('user-form-username').value = '';
  document.getElementById('user-form-password').value = '';
  document.getElementById('user-form-role').value = 'User';
  document.getElementById('user-form-active').checked = true;
  
  const deptSelect = document.getElementById('user-form-dept');
  deptSelect.innerHTML = dropdownData.departments.map(d => `<option value="${d.Code}">${d.Code} - ${d.Name}</option>`).join('');
  
  document.getElementById('user-modal').classList.add('active');
}

function openEditUserModal(id) {
  const u = dropdownData.users.find(x => x.ID === id);
  if (!u) return;
  
  document.getElementById('user-modal-title').innerText = 'Edit User Profile';
  document.getElementById('user-form-id').value = u.ID;
  document.getElementById('user-form-fullname').value = u.Fullname;
  document.getElementById('user-form-username').value = u.Username;
  document.getElementById('user-form-password').value = u.Password || '';
  document.getElementById('user-form-role').value = u.Role;
  
  const deptSelect = document.getElementById('user-form-dept');
  deptSelect.innerHTML = dropdownData.departments.map(d => `<option value="${d.Code}" ${d.Code === u.Department ? 'selected' : ''}>${d.Code} - ${d.Name}</option>`).join('');
  
  document.getElementById('user-form-active').checked = u.Status !== 'Inactive';
  document.getElementById('user-modal').classList.add('active');
}

function closeUserModal() {
  document.getElementById('user-modal').classList.remove('active');
}

function saveUser(e) {
  e.preventDefault();
  const id = document.getElementById('user-form-id').value;
  const fullname = document.getElementById('user-form-fullname').value;
  const username = document.getElementById('user-form-username').value;
  const password = document.getElementById('user-form-password').value;
  const role = document.getElementById('user-form-role').value;
  const dept = document.getElementById('user-form-dept').value;
  
  const payload = {
    Fullname: fullname,
    Username: username,
    Password: password,
    Role: role,
    Department: dept,
    Status: document.getElementById('user-form-active').checked ? 'Active' : 'Inactive'
  };
  
  showLoading(true);
  if (id) {
    google.script.run.withSuccessHandler(function(res) {
      showLoading(false);
      if (res.success) {
        showToast('Profil user berhasil diperbarui');
        closeUserModal();
        loadDropdownData();
        setTimeout(() => loadMasterDataTables('master-user'), 500);
      } else {
        alert("Gagal mengupdate user: " + res.error);
      }
    }).withFailureHandler(function(err) {
      showLoading(false);
      alert(err.toString());
    }).editUserRecord(id, payload);
  } else {
    google.script.run.withSuccessHandler(function(res) {
      showLoading(false);
      if (res.success) {
        showToast('User baru berhasil ditambahkan');
        closeUserModal();
        loadDropdownData();
        setTimeout(() => loadMasterDataTables('master-user'), 500);
      } else {
        alert("Gagal menambahkan user: " + res.error);
      }
    }).withFailureHandler(function(err) {
      showLoading(false);
      alert(err.toString());
    }).createUserRecord(payload);
  }
}

function deleteUser(id) {
  if (id === currentUser.ID) {
    alert("Anda tidak dapat menghapus akun Anda sendiri!");
    return;
  }
  if (confirm("Apakah Anda yakin ingin menghapus user ini dari sistem?")) {
    showLoading(true);
    google.script.run.withSuccessHandler(function(res) {
      showLoading(false);
      if (res.success) {
        showToast('User berhasil dihapus');
        loadDropdownData();
        setTimeout(() => loadMasterDataTables('master-user'), 500);
      } else {
        alert("Gagal menghapus user: " + res.error);
      }
    }).withFailureHandler(function(err) {
      showLoading(false);
      alert(err.toString());
    }).deleteUserRecord(id);
  }
}

function populateMatrixDeptDropdown(selectedVal) {
  const select = document.getElementById('matrix-form-department');
  if (select) {
    let optionsHtml = '<option value="ALL">ALL (Global Fallback)</option>';
    if (dropdownData && dropdownData.departments) {
      optionsHtml += dropdownData.departments.map(d => `<option value="${d.Code}">${d.Code} - ${d.Name}</option>`).join('');
    }
    select.innerHTML = optionsHtml;
    select.value = selectedVal || 'ALL';
  }
}

function openAddMatrixModal() {
  document.getElementById('matrix-modal-title').textContent = 'Tambah Matrix Approval Baru';
  document.getElementById('matrix-form-id').value = '';
  document.getElementById('matrix-form-doctype').value = 'PD';
  
  populateMatrixDeptDropdown('ALL');
  
  document.getElementById('matrix-form-minamount').value = 0;
  document.getElementById('matrix-form-maxamount').value = 99999999999;
  
  for (let i = 1; i <= 5; i++) {
    document.getElementById('matrix-step-' + i).value = 'None';
  }
  
  document.getElementById('matrix-modal').classList.add('active');
}

function openEditMatrixModal(id) {
  const m = dropdownData.matrix.find(x => x.ID === id);
  if (!m) return;
  
  document.getElementById('matrix-modal-title').textContent = 'Edit Matrix Approval';
  document.getElementById('matrix-form-id').value = m.ID;
  document.getElementById('matrix-form-doctype').value = m.DocType;
  
  populateMatrixDeptDropdown(m.Department || 'ALL');
  
  document.getElementById('matrix-form-minamount').value = parseFloat(m.MinAmount) || 0;
  document.getElementById('matrix-form-maxamount').value = parseFloat(m.MaxAmount) || 99999999999;
  
  const steps = m.Steps.split(',').map(s => s.trim());
  for (let i = 1; i <= 5; i++) {
    const select = document.getElementById('matrix-step-' + i);
    select.value = steps[i - 1] || 'None';
  }
  
  document.getElementById('matrix-modal').classList.add('active');
}

function closeMatrixModal() {
  document.getElementById('matrix-modal').classList.remove('active');
}

function saveMatrix(e) {
  e.preventDefault();
  const id = document.getElementById('matrix-form-id').value;
  const docType = document.getElementById('matrix-form-doctype').value;
  const department = document.getElementById('matrix-form-department').value;
  const minAmount = parseFloat(document.getElementById('matrix-form-minamount').value) || 0;
  const maxAmount = parseFloat(document.getElementById('matrix-form-maxamount').value) || 0;
  const steps = [];
  
  for (let i = 1; i <= 5; i++) {
    const val = document.getElementById('matrix-step-' + i).value;
    if (val !== 'None') {
      steps.push(val);
    }
  }
  
  if (steps.length === 0) {
    alert("Minimal harus ada 1 alur approval!");
    return;
  }
  
  const payload = {
    DocType: docType,
    Department: department,
    MinAmount: minAmount,
    MaxAmount: maxAmount,
    Steps: steps.join(', ')
  };
  
  showLoading(true);
  const successHandler = function(res) {
    showLoading(false);
    if (res.success) {
      showToast(id ? 'Matrix approval berhasil diperbarui' : 'Matrix approval baru berhasil ditambahkan');
      closeMatrixModal();
      loadDropdownData();
      setTimeout(() => loadMasterDataTables('matrix'), 500);
    } else {
      alert("Gagal menyimpan matrix: " + res.error);
    }
  };
  
  const failureHandler = function(err) {
    showLoading(false);
    alert(err.toString());
  };
  
  if (id) {
    google.script.run.withSuccessHandler(successHandler).withFailureHandler(failureHandler).updateMasterRecord('t_approval_matrix', id, payload);
  } else {
    google.script.run.withSuccessHandler(successHandler).withFailureHandler(failureHandler).createMasterRecord('t_approval_matrix', 'AM', payload);
  }
}

function deleteMatrix(id) {
  if (confirm("Apakah Anda yakin ingin menghapus matrix approval ini?")) {
    showLoading(true);
    google.script.run.withSuccessHandler(function(res) {
      showLoading(false);
      if (res.success) {
        showToast('Matrix approval berhasil dihapus');
        loadDropdownData();
        setTimeout(() => loadMasterDataTables('matrix'), 500);
      } else {
        alert("Gagal menghapus matrix: " + res.error);
      }
    }).withFailureHandler(function(err) {
      showLoading(false);
      alert(err.toString());
    }).deleteMasterRecord('t_approval_matrix', id);
  }
}

function previewBudgetCapture(input) {
  const container = document.getElementById('pd-budget-capture-preview-container');
  const preview = document.getElementById('pd-budget-capture-preview');
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = function(e) {
      if (preview) preview.src = e.target.result;
      if (container) container.style.display = 'block';
    };
    reader.readAsDataURL(input.files[0]);
  } else {
    if (preview) preview.src = '';
    if (container) container.style.display = 'none';
  }
}

function toggleNotifDropdown(event) {
  if (event) event.stopPropagation();
  const dropdown = document.getElementById('notif-dropdown');
  if (!dropdown) return;
  const isCurrentlyVisible = dropdown.style.display === 'block';
  
  if (isCurrentlyVisible) {
    dropdown.style.display = 'none';
  } else {
    dropdown.style.display = 'block';
    // Clear badge and unread count since they have been opened/viewed
    const badge = document.getElementById('notif-badge');
    const unreadCount = document.getElementById('notif-unread-count');
    if (badge) badge.style.display = 'none';
    if (unreadCount) unreadCount.style.display = 'none';
  }
}

// Click outside to close notifications dropdown
window.addEventListener('click', function(e) {
  const dropdown = document.getElementById('notif-dropdown');
  const btn = document.getElementById('notif-bell-btn');
  if (dropdown && dropdown.style.display === 'block') {
    if (!dropdown.contains(e.target) && (!btn || !btn.contains(e.target))) {
      dropdown.style.display = 'none';
    }
  }
});

function renderPDFToCanvases(base64Data, container) {
  if (!window.pdfjsLib) {
    container.textContent = 'PDF.js library not loaded.';
    return Promise.resolve();
  }
  
  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
  
  try {
    const pdfData = atob(base64Data.split(',')[1]);
    const loadingTask = pdfjsLib.getDocument({data: pdfData});
    return loadingTask.promise.then(function(pdf) {
      container.innerHTML = ''; // Clear loading message
      
      const renderPagePromises = [];
      for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
        const pagePromise = pdf.getPage(pageNum).then(function(page) {
          const viewport = page.getViewport({scale: 1.5});
          const canvas = document.createElement('canvas');
          canvas.style.display = 'block';
          canvas.style.margin = '20px auto';
          canvas.style.maxWidth = '100%';
          canvas.style.height = 'auto';
          canvas.style.boxShadow = '0 4px 10px rgba(0,0,0,0.1)';
          
          canvas.width = viewport.width;
          canvas.height = viewport.height;
          
          const context = canvas.getContext('2d');
          const renderContext = {
            canvasContext: context,
            viewport: viewport
          };
          
          return page.render(renderContext).promise.then(() => {
            container.appendChild(canvas);
          });
        });
        renderPagePromises.push(pagePromise);
      }
      return Promise.all(renderPagePromises);
    }).catch(err => {
      console.error(err);
      container.textContent = 'Gagal menampilkan PDF: ' + err.message;
    });
  } catch (e) {
    console.error(e);
    container.textContent = 'Gagal memproses file PDF.';
    return Promise.resolve();
  }
}
</script>

