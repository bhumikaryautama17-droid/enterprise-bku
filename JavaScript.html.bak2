 * BUDGET CONTROL VIEW LOGIC
 */
function loadBudgetDashboard() {
  const dept = document.getElementById('budget-filter-dept').value;
  const project = document.getElementById('budget-filter-project').value;
  const year = document.getElementById('budget-filter-year').value;
  
  showLoading(true);
  google.script.run.withSuccessHandler(function(data) {
    showLoading(false);
    
    document.getElementById('budg-total').innerText = formatRupiah(data.kpis.totalBudget);
    document.getElementById('budg-actual').innerText = formatRupiah(data.kpis.budgetActual);
    document.getElementById('budg-avail').innerText = formatRupiah(data.kpis.budgetAvailable);
    document.getElementById('budg-util-percent').innerText = data.kpis.utilizationPercent + "%";
    
    // Render charts
    renderBudgetCharts(data.charts);
    
  }).withFailureHandler(function(err) {
    showLoading(false);
    alert(err.toString());
  }).getBudgetDashboard(dept, project, year);
}

function renderBudgetCharts(chartsData) {
  // 1. Budget per department (Pie)
  if (charts.budgetPie) charts.budgetPie.destroy();
  const ctxPie = document.getElementById('chart-budget-pie').getContext('2d');
  charts.budgetPie = new Chart(ctxPie, {
    type: 'pie',
    data: {
      labels: chartsData.labels,
      datasets: [{
        data: chartsData.annual,
        backgroundColor: ['#00e5ff', '#ffb300', '#2979ff', '#00e676', '#ff1744', '#d500f9', '#9ca3af']
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'right', labels: { color: '#f3f4f6', boxWidth: 10 } }
      }
    }
  });

  // 2. Budget vs Actual bar chart
  if (charts.budgetBar) charts.budgetBar.destroy();
  const ctxBar = document.getElementById('chart-budget-bar').getContext('2d');
  charts.budgetBar = new Chart(ctxBar, {
    type: 'bar',
    data: {
      labels: chartsData.labels,
      datasets: [
        {
          label: 'Annual Budget',
          data: chartsData.annual,
          backgroundColor: 'rgba(41, 121, 255, 0.6)',
          borderColor: '#2979ff',
          borderWidth: 1
        },
        {
          label: 'Actual Spent',
          data: chartsData.actual,
          backgroundColor: 'rgba(0, 230, 118, 0.6)',
          borderColor: '#00e676',
          borderWidth: 1
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: '#f3f4f6' } }
      },
      scales: {
        x: { ticks: { color: '#9ca3af' } },
        y: { ticks: { color: '#9ca3af' } }
      }
    }
  });
}

/* =============================================
   BUDGET TAHUNAN CRUD (LIVE GAS)
   ============================================= */

// State sementara untuk data budget di memory
var _budgetData = [];

function loadBudgetTahunan() {
  const isAdmin = currentUser && currentUser.role === 'Administrator';
  showLoading(true);

  google.script.run
    .withSuccessHandler(function(res) {
      showLoading(false);
      if (!res.success) { alert('Gagal memuat data budget: ' + (res.error || '')); return; }
      _budgetData = res.data || [];
      _renderBudgetTable(isAdmin);
      _setupBudgetAdminUI(isAdmin);
    })
    .withFailureHandler(function(err) {
      showLoading(false);
      alert(err.toString());
    })
    .getBudgetTahunanList();
}

function _setupBudgetAdminUI(isAdmin) {
  const adminBar = document.getElementById('live-budget-admin-bar');
  const userBar  = document.getElementById('live-budget-user-bar');
  if (adminBar) adminBar.style.display = isAdmin ? 'flex' : 'none';
  if (userBar)  userBar.style.display  = isAdmin ? 'none' : 'block';

  document.querySelectorAll('.live-budget-admin-col').forEach(el => {
    el.style.display = isAdmin ? '' : 'none';
  });

  // Isi dropdown departemen di modal dari dropdownData
  const deptSel = document.getElementById('live-budgetFormDept');
  if (deptSel && dropdownData.departments) {
    deptSel.innerHTML = '<option value="">-- Pilih Departemen --</option>' +
      dropdownData.departments.map(d => `<option value="${d.code}">${d.code}</option>`).join('');
  }
}

function _renderBudgetTable(isAdmin) {
  const tbody = document.getElementById('live-budgTahunanTbody');
  if (!tbody) return;
  tbody.innerHTML = '';

  if (!_budgetData.length) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:20px;color:#9ca3af">Belum ada data budget tahunan</td></tr>';
    return;
  }

  _budgetData.forEach(function(b, i) {
    const ann   = b.annualBudget || 0;
    const act   = b.actualBudget || 0;
    const avail = ann - act;
    const util  = ann > 0 ? Math.round(act / ann * 100) : 0;
    const utilClass = util > 80 ? 'rejected' : util > 60 ? 'pending' : 'approved';
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${i + 1}</td>
      <td><strong>${b.dept || '-'}</strong></td>
      <td>${b.year || '-'}</td>
      <td style="font-weight:700">${formatRupiah(ann)}</td>
      <td>${formatRupiah(act)}</td>
      <td style="color:#00e676;font-weight:700">${formatRupiah(avail)}</td>
      <td><span class="status-pill ${utilClass}">${util}%</span></td>
      <td class="live-budget-admin-col" style="${isAdmin ? '' : 'display:none;'} text-align:center;">
        <button class="action-btn edit-btn" onclick="openEditBudgetLiveModal('${b.id}')" title="Edit">
          <i class="fas fa-edit"></i>
        </button>
        <button class="action-btn reject-btn" onclick="deleteBudgetLive('${b.id}')" title="Hapus">
          <i class="fas fa-trash"></i>
        </button>
      </td>`;
    tbody.appendChild(tr);
  });
}

function openAddBudgetLiveModal() {
  document.getElementById('live-budgetModalTitle').textContent = 'Tambah Budget Tahunan';
  document.getElementById('live-budgetFormId').value    = '';
  document.getElementById('live-budgetFormDept').value  = '';
  document.getElementById('live-budgetFormYear').value  = new Date().getFullYear();
  document.getElementById('live-budgetFormAnnual').value = '';
  document.getElementById('live-budgetFormActual').value = '';
  document.getElementById('live-budgetFormAnnualPreview').textContent = '';
  document.getElementById('live-budgetFormActualPreview').textContent = '';
  document.getElementById('live-budgetModal').classList.add('active');
}

function openEditBudgetLiveModal(id) {
  const b = _budgetData.find(x => x.id === id);
  if (!b) return alert('Data budget tidak ditemukan');
  document.getElementById('live-budgetModalTitle').textContent = 'Edit Budget Tahunan';
  document.getElementById('live-budgetFormId').value    = b.id;
  document.getElementById('live-budgetFormDept').value  = b.dept || '';
  document.getElementById('live-budgetFormYear').value  = b.year || '';
  document.getElementById('live-budgetFormAnnual').value = b.annualBudget || 0;
  document.getElementById('live-budgetFormActual').value = b.actualBudget || 0;
  document.getElementById('live-budgetFormAnnualPreview').textContent = formatRupiah(b.annualBudget || 0);
  document.getElementById('live-budgetFormActualPreview').textContent = formatRupiah(b.actualBudget || 0);
  document.getElementById('live-budgetModal').classList.add('active');
}

function closeBudgetLiveModal() {
  document.getElementById('live-budgetModal').classList.remove('active');
}

function saveBudgetLive(e) {
  e.preventDefault();
  const id     = document.getElementById('live-budgetFormId').value.trim();
  const dept   = document.getElementById('live-budgetFormDept').value.trim();
  const year   = parseInt(document.getElementById('live-budgetFormYear').value) || 0;
  const annual = parseFloat(document.getElementById('live-budgetFormAnnual').value) || 0;
  const actual = parseFloat(document.getElementById('live-budgetFormActual').value) || 0;

  if (!dept || !year) return alert('Departemen dan Tahun wajib diisi');

  showLoading(true);
  google.script.run
    .withSuccessHandler(function(res) {
      showLoading(false);
      if (!res.success) { alert('Gagal menyimpan: ' + (res.error || '')); return; }
      closeBudgetLiveModal();
      loadBudgetTahunan();
    })
    .withFailureHandler(function(err) {
      showLoading(false);
      alert(err.toString());
    })
    .saveBudgetRecord({ id: id || null, dept, year, annualBudget: annual, actualBudget: actual });
}

function deleteBudgetLive(id) {
  if (!confirm('Hapus data budget ini? Tindakan tidak dapat diurungkan.')) return;
  showLoading(true);
  google.script.run
    .withSuccessHandler(function(res) {
      showLoading(false);
      if (!res.success) { alert('Gagal menghapus: ' + (res.error || '')); return; }
      loadBudgetTahunan();
    })
    .withFailureHandler(function(err) {
      showLoading(false);
      alert(err.toString());
    })
    .deleteBudgetRecord(id);
}

function exportBudgetLiveCSV() {
  if (!_budgetData.length) return alert('Tidak ada data untuk diekspor');
  const headers = ['No', 'Department', 'Tahun', 'Annual Budget', 'Actual Budget', 'Available', 'Utilization (%)'];
  const rows = _budgetData.map(function(b, i) {
    const ann   = b.annualBudget || 0;
    const act   = b.actualBudget || 0;
    const avail = ann - act;
    const util  = ann > 0 ? Math.round(act / ann * 100) : 0;
    return [i + 1, b.dept || '', b.year || '', ann, act, avail, util + '%'];
  });
  let csv = '\uFEFF' + headers.join(',') + '\n';
  rows.forEach(r => { csv += r.map(v => `"${v}"`).join(',') + '\n'; });

  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url;
  a.download = `Budget_Tahunan_${new Date().getFullYear()}.csv`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

function downloadBudgetLiveTemplate() {
  const csv = '\uFEFFDepartment,Tahun,Annual Budget,Actual Budget\nHRGA,2026,650000000,420000000\nQAQC,2026,300000000,190000000\n';
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url;
  a.download = 'Template_Import_Budget.csv';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

function importBudgetLiveCSV(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const text  = e.target.result.replace(/^\uFEFF/, '');
      const lines = text.split(/\r?\n/).filter(l => l.trim());
      if (lines.length < 2) return alert('File CSV kosong atau tidak valid');

      const headers   = lines[0].split(',').map(h => h.replace(/"/g, '').trim().toLowerCase());
      const deptIdx   = headers.findIndex(h => h.includes('department') || h.includes('dept'));
      const yearIdx   = headers.findIndex(h => h.includes('tahun') || h.includes('year'));
      const annualIdx = headers.findIndex(h => h.includes('annual'));
      const actualIdx = headers.findIndex(h => h.includes('actual'));

      if (deptIdx < 0 || yearIdx < 0 || annualIdx < 0) {
        return alert('Header CSV tidak sesuai. Pastikan ada kolom: Department, Tahun, Annual Budget');
      }

      const rows = [];
      for (let i = 1; i < lines.length; i++) {
        const cols = lines[i].split(',').map(c => c.replace(/"/g, '').trim());
        const dept   = cols[deptIdx] || '';
        const year   = parseInt(cols[yearIdx]) || 0;
        const annual = parseFloat(cols[annualIdx]) || 0;
        const actual = actualIdx >= 0 ? parseFloat(cols[actualIdx]) || 0 : 0;
        if (!dept || !year) continue;
        rows.push({ dept, year, annualBudget: annual, actualBudget: actual });
      }

      if (!rows.length) return alert('Tidak ada data valid di file CSV');
      if (!confirm(`Import ${rows.length} baris data budget? Data akan ditambahkan ke yang sudah ada.`)) return;

      showLoading(true);
      google.script.run
        .withSuccessHandler(function(res) {
          showLoading(false);
          if (!res.success) { alert('Gagal import: ' + (res.error || '')); return; }
          alert(`${res.count} data budget berhasil diimport`);
          loadBudgetTahunan();
        })
        .withFailureHandler(function(err) {
          showLoading(false);
          alert(err.toString());
        })
        .importBudgetData(rows);
    } catch(err) {
      alert('Gagal membaca file: ' + err.message);
    }
    input.value = '';
  };
  reader.readAsText(file, 'UTF-8');
}

/**
 * SYSTEM AUDIT TRAILS
 */
function loadAuditTrail() {
  showLoading(true);
  google.script.run.withSuccessHandler(function(logs) {
    showLoading(false);
    const tbody = document.getElementById('audit-tbody');
    tbody.innerHTML = '';
    
    logs.forEach((log, idx) => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${idx + 1}</td>
        <td>${log.timestamp}</td>
        <td><strong>${log.user}</strong></td>
        <td>${log.activity}</td>
        <td><span class="status-pill draft">${log.module}</span></td>
        <td>${log.docNumber}</td>
        <td><code style="color:var(--accent-cyan);">${log.ipAddress}</code></td>
      `;
      tbody.appendChild(tr);
    });
  }).withFailureHandler(function(err) {
    showLoading(false);
    alert(err.toString());
  }).getAuditTrail();
}

/**
 * SYSTEM MASTER TABLES
 */
function loadMasterDataTables(viewName) {
  const isAdmin = currentUser && currentUser.role === 'Administrator';
  
  if (!dropdownData.departments) {
    loadDropdownData();
    return;
  }
  
  if (viewName === 'master-dept') {
    const tbody = document.getElementById('master-dept-tbody');
    tbody.innerHTML = dropdownData.departments.map((d, i) => `
      <tr>
        <td>${i+1}</td>
        <td><strong>${d.Code}</strong></td>
        <td>${d.Name}</td>
        <td><span class="status-pill approved">Active</span></td>
      </tr>
    `).join('');
  } else if (viewName === 'master-coa') {
    const tbody = document.getElementById('master-coa-tbody');
    tbody.innerHTML = dropdownData.coas.map((c, i) => `
      <tr>
        <td>${i+1}</td>
        <td><strong>${c.Code}</strong></td>
        <td>${c.Name}</td>
        <td><span class="status-pill approved">Active</span></td>
      </tr>
    `).join('');
  } else if (viewName === 'master-user') {
    document.getElementById('admin-user-actions').style.display = isAdmin ? 'block' : 'none';
    const headers = document.querySelectorAll('#view-master-user .admin-only-header');
    headers.forEach(h => h.style.display = isAdmin ? 'table-cell' : 'none');

    const tbody = document.getElementById('master-user-tbody');
    tbody.innerHTML = dropdownData.users.map((u, i) => `
      <tr>
        <td>${i+1}</td>
        <td><strong>${u.Username}</strong></td>
        <td>${u.Fullname}</td>
        <td><span class="status-pill pending">${u.Role}</span></td>
        <td>${u.Department}</td>
        <td><span class="status-pill ${u.Status === 'Inactive' ? 'rejected' : 'approved'}">${u.Status || 'Active'}</span></td>
        ${isAdmin ? `<td style="text-align:center;">
          <button class="form-btn" style="padding:4px 8px;font-size:10px;margin-right:4px;" onclick="openEditUserModal('${u.ID}')"><i class="fas fa-edit"></i> Edit</button>
          <button class="form-btn danger" style="padding:4px 8px;font-size:10px;" onclick="deleteUser('${u.ID}')"><i class="fas fa-trash"></i> Hapus</button>
        </td>` : ''}
      </tr>
    `).join('');
  } else if (viewName === 'matrix') {
    const headers = document.querySelectorAll('#view-matrix .admin-only-header');
    headers.forEach(h => h.style.display = isAdmin ? 'table-cell' : 'none');

    const tbody = document.getElementById('matrix-tbody');
    tbody.innerHTML = dropdownData.matrix.map((m, i) => `
      <tr>
        <td>${i+1}</td>
        <td><span class="status-pill ${m.DocType.toLowerCase() === 'pr' ? 'pending' : 'approved'}">${m.DocType}</span></td>
        <td><strong>${m.Department || 'ALL'}</strong></td>
        <td>${formatRupiah(m.MinAmount)}</td>
        <td>${formatRupiah(m.MaxAmount)}</td>
        <td>${m.Steps.split(',').map((s, idx) => `<span class="status-pill draft" style="margin:2px;">${idx+1}. ${s.trim()}</span>`).join('')}</td>
        ${isAdmin ? `<td style="text-align:center;">
          <button class="form-btn" style="padding:4px 8px;font-size:10px;margin-right:4px;" onclick="openEditMatrixModal('${m.ID}')"><i class="fas fa-edit"></i> Edit</button>
          <button class="form-btn danger" style="padding:4px 8px;font-size:10px;" onclick="deleteMatrix('${m.ID}')"><i class="fas fa-trash"></i> Hapus</button>
        </td>` : ''}
      </tr>
    `).join('');
  }
}

/**
 * METADATA LOADING UTILITIES
 */
function loadDropdownData() {
  google.script.run.withSuccessHandler(function(data) {
    dropdownData = data;
    
    // Safety check for switcher
    const switcher = document.getElementById('user-role-select');
    if (switcher) {
      switcher.innerHTML = data.users.map(u => `
        <option value="${u.Username}" ${u.Username === currentUser.username ? 'selected' : ''}>
          ${u.Fullname} (${u.Role})
        </option>
      `).join('');
    }
  }).getDropdownData();
}

/**
 * UI UTILITY HELPERS
 */
function formatRupiah(val) {
  return "Rp " + new Intl.NumberFormat('id-ID').format(val);
}

function showLoading(visible) {
  const overlay = document.getElementById('loading-overlay');
  if (visible) {
    overlay.style.display = 'flex';
  } else {
    overlay.style.display = 'none';
  }
}

function showToast(message) {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = 'toast-alert';
  toast.style.background = 'var(--bg-secondary)';
  toast.style.border = '1px solid var(--accent-cyan)';
  toast.style.color = 'var(--text-primary)';
  toast.style.padding = '12px 24px';
  toast.style.borderRadius = '8px';
  toast.style.marginBottom = '10px';
  toast.style.boxShadow = '0 8px 24px rgba(0,229,255,0.1)';
  toast.style.display = 'flex';
  toast.style.alignItems = 'center';
  toast.style.gap = '10px';
  toast.style.fontSize = '12px';
  toast.style.fontWeight = '600';
  toast.innerHTML = `<i class="fas fa-check-circle" style="color:var(--accent-cyan);"></i> ${message}`;
  
  container.appendChild(toast);
  setTimeout(() => {
    toast.remove();
  }, 4000);
}

/**
 * CUSTOM SIGNATURE CANVAS CONTROLLERS
 */
let canvas, ctx;
let isDrawing = false;
let lastX = 0;
let lastY = 0;

function setupSignatureCanvas() {
  canvas = document.getElementById('signature-canvas');
  if (!canvas) return;
  ctx = canvas.getContext('2d');
  
  ctx.strokeStyle = '#121b2d';
  ctx.lineWidth = 3;
  ctx.lineCap = 'round';
  ctx.lineJoin = 'round';
  
  canvas.addEventListener('mousedown', (e) => {
    isDrawing = true;
    [lastX, lastY] = getMousePos(canvas, e);
  });
  canvas.addEventListener('mousemove', drawStroke);
  canvas.addEventListener('mouseup', () => isDrawing = false);
  canvas.addEventListener('mouseout', () => isDrawing = false);
  
  // Touch support
  canvas.addEventListener('touchstart', (e) => {
    isDrawing = true;
    const touch = e.touches[0];
    [lastX, lastY] = getTouchPos(canvas, touch);
    e.preventDefault();
  }, { passive: false });
  
  canvas.addEventListener('touchmove', (e) => {
    if (!isDrawing) return;
    const touch = e.touches[0];
    const [x, y] = getTouchPos(canvas, touch);
    ctx.beginPath();
    ctx.moveTo(lastX, lastY);
    ctx.lineTo(x, y);
    ctx.stroke();
    [lastX, lastY] = [x, y];
    e.preventDefault();
  }, { passive: false });
  
  canvas.addEventListener('touchend', () => isDrawing = false);
}

function getMousePos(canvasDom, mouseEvent) {
  const rect = canvasDom.getBoundingClientRect();
  return [
    mouseEvent.clientX - rect.left,
    mouseEvent.clientY - rect.top
  ];
}

function getTouchPos(canvasDom, touchEvent) {
  const rect = canvasDom.getBoundingClientRect();
  return [
    touchEvent.clientX - rect.left,
    touchEvent.clientY - rect.top
  ];
}

function drawStroke(e) {
  if (!isDrawing) return;
  const [x, y] = getMousePos(canvas, e);
  ctx.beginPath();
  ctx.moveTo(lastX, lastY);
  ctx.lineTo(x, y);
  ctx.stroke();
  [lastX, lastY] = [x, y];
}

function clearSignatureCanvas() {
  if (!ctx) return;
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  const uploadInput = document.getElementById('signature-upload');
  if (uploadInput) uploadInput.value = '';
}

function handleSignatureUpload(event) {
  const file = event.target.files[0];
  if (!file) return;
  
  const reader = new FileReader();
  reader.onload = function(e) {
    const img = new Image();
    img.onload = function() {
      if (!ctx || !canvas) return;
      // Clear canvas
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      // Calculate fit dimensions
      const wrh = img.width / img.height;
      let newWidth = canvas.width;
      let newHeight = newWidth / wrh;
      if (newHeight > canvas.height) {
        newHeight = canvas.height;
        newWidth = newHeight * wrh;
      }
      
      const xOffset = (canvas.width - newWidth) / 2;
      const yOffset = (canvas.height - newHeight) / 2;
      
      ctx.drawImage(img, xOffset, yOffset, newWidth, newHeight);
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function openSignatureModal() {
  document.getElementById('signature-modal').classList.add('active');
  clearSignatureCanvas();
  
  const preview = document.getElementById('active-signature-preview');
  if (currentUser.signature) {
    preview.innerHTML = `<img src="${currentUser.signature}" style="max-height:55px; max-width:280px; object-fit:contain;" />`;
  } else {
    preview.innerHTML = `<span style="font-size:11px; color:var(--text-muted); font-style:italic;">Belum ada tanda tangan kustom</span>`;
  }
}

function closeSignatureModal() {
  document.getElementById('signature-modal').classList.remove('active');
}

function saveSignature() {
  const blank = document.createElement('canvas');
  blank.width = canvas.width;
  blank.height = canvas.height;
  if (canvas.toDataURL() === blank.toDataURL()) {
    alert("Silakan gambar tanda tangan Anda terlebih dahulu.");
    return;
  }
  
  const base64Data = canvas.toDataURL('image/png');
  
  showLoading(true);
  google.script.run.withSuccessHandler(function(res) {
    showLoading(false);
    if (res.success) {
      currentUser.signature = base64Data;
      sessionStorage.setItem('currentUser', JSON.stringify(currentUser));
      openSignatureModal(); // Refresh active preview
      showToast('Tanda tangan kustom Anda berhasil disimpan.');
    } else {
      alert("Gagal menyimpan tanda tangan: " + res.error);
    }
  }).withFailureHandler(function(err) {
    showLoading(false);
    alert(err.toString());
  }).saveUserSignature(currentUser.username, base64Data);
}

/**
 * PDF GENERATION HANDLERS
 */
function genSVGSig(name) {
  let h = 0;
  for(let i = 0; i < name.length; i++) h = name.charCodeAt(i) + ((h << 5) - h);
  const g = (s, sc) => Math.sin(s + h) * sc;
  const path = `M 10,${23+g(1,4)} Q 28,${12+g(2,7)} 46,${23+g(3,4)} T 80,${20+g(4,6)} Q 98,${36+g(5,5)} 115,${22+g(6,4)} M 7,${29+g(7,3)} C 45,${42+g(8,2)} 90,${40+g(9,2)} 126,${30+g(10,3)}`;
  return `<svg class="esig" viewBox="0 0 135 48"><path d="${path}"/></svg>`;
}

function buildPaperHTML(doc) {
  const sigs = doc.sigs;
  
  const formatDate = function(dateStr) {
    if (!dateStr) return '-';
    const d = new Date(dateStr);
    return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' });
  };
  
  const formatCurrency = function(num) {
    return "Rp " + new Intl.NumberFormat('id-ID').format(num || 0);
  };
  
  const terbilangText = terbilangLocal(doc.nominal);
  
  const getSignerName = (role, dept, defaultName) => {
    if (!dropdownData || !dropdownData.users) return defaultName;
    const u = dropdownData.users.find(user => user.Role === role && (dept ? user.Department === dept : true));
    return u ? u.Fullname : defaultName;
  };

  const getSigBoxData = function(sigObj, roleKey) {
    let sigContent = '';
    let name = '-';
    let date = '';
    let statusClass = 'pend';
    let statusText = 'PENDING';
    
    if (sigObj && (sigObj.status === 'SUBMITTED' || sigObj.status === 'APPROVED')) {
      name = sigObj.name;
      date = formatDate(sigObj.date);
      statusClass = 'app';
      statusText = sigObj.status === 'SUBMITTED' ? 'SUBMITTED' : 'APPROVED';
      if (sigObj.signatureText && sigObj.signatureText.indexOf('data:image') === 0) {
        sigContent = '<img src="' + sigObj.signatureText + '" style="max-height:40px; max-width:110px; object-fit:contain;" />';
      } else if (sigObj.signature && sigObj.signature.indexOf('data:image') === 0) {
        sigContent = '<img src="' + sigObj.signature + '" style="max-height:40px; max-width:110px; object-fit:contain;" />';
      } else {
        sigContent = genSVGSig(sigObj.name).replace('class="esig"','style="width:110px;height:38px"').replace('stroke:var(--cy)','stroke:#1565c0');
      }
    } else if (sigObj && sigObj.status === 'REJECTED') {
      name = sigObj.name;
      date = formatDate(sigObj.date);
      statusClass = 'rej';
      statusText = 'REJECTED';
      sigContent = '<span style="color:#ff1744; font-weight:bold; font-size:9px;">REJECTED</span>';
    } else if (roleKey) {
      const signerName = getSignerName(roleKey, '', '');
      if (dropdownData && dropdownData.users) {
        const dbUser = dropdownData.users.find(user => user.Fullname === signerName);
        if (dbUser && dbUser.Signature && dbUser.Signature.indexOf('data:image') === 0) {
          sigContent = '<img src="' + dbUser.Signature + '" style="max-height:40px; max-width:110px; object-fit:contain; opacity:0.9;" />';
        }
      }
    }
    
    return {
      content: sigContent,
      name: name,
      date: date,
      statusText: statusText,
      statusClass: statusClass
    };
  };

  if (doc.type === 'PR') {
    let itemsRowsHTML = '';
    doc.items.forEach(function(item, idx) {
      itemsRowsHTML += '<tr>' +
        '<td style="border:1px solid #111; padding:5px; text-align:center;">' + (idx + 1) + '</td>' +
        '<td style="border:1px solid #111; padding:5px; text-align:center; font-weight:bold;">' + (item.coa || item.COA || '-') + '</td>' +
        '<td style="border:1px solid #111; padding:5px; text-align:center;">' + (item.partNo || item.PartNumber || '-') + '</td>' +
        '<td style="border:1px solid #111; padding:5px;">' + (item.desc || item.Description || '-') + '</td>' +
        '<td style="border:1px solid #111; padding:5px; text-align:center;">' + (item.costElement || item.CostElement || '-') + '</td>' +
        '<td style="border:1px solid #111; padding:5px; text-align:center; font-weight:bold;">' + (item.qty || item.Quantity || 0) + '</td>' +
        '<td style="border:1px solid #111; padding:5px; text-align:center;">' + (item.uom || item.UoM || 'Unit') + '</td>' +
        '</tr>';
    });
    
    const isStock = doc.inventoryType === 'STOCK' ? '&#10003;' : '&nbsp;&nbsp;';
    const isNonStock = doc.inventoryType === 'NON STOCK' || !doc.inventoryType ? '&#10003;' : '&nbsp;&nbsp;';
    
    const getPRSupervisor = (dept) => {
      const mapping = {
        'HRGA': 'Mona Asrani',
        'SHE': 'Rosmina Rabbang',
        'External': 'Erwin Eka',
        'QAQC': 'Yusril',
        'Engineering': 'Roymon Biang',
        'Plant': 'Muh. Said',
        'Eksplorasi': 'Laode Rusman',
        'Exploration': 'Laode Rusman'
      };
      return mapping[dept] || '';
    };


    const sigUser = getSigBoxData(sigs.user, 'user');
    const sigSupervisor = getSigBoxData(sigs.supervisor, 'supervisor');
    const sigFin = getSigBoxData(sigs.finance, 'finance');
    const sigPm = getSigBoxData(sigs.projectManager, 'projectManager');
    
    if (sigUser.name === '-') sigUser.name = doc.requester || 'Mona Asrani';
    if (sigSupervisor.name === '-') sigSupervisor.name = getPRSupervisor(doc.dept);
    if (sigFin.name === '-') sigFin.name = 'Putri Amalia';
    if (sigPm.name === '-') sigPm.name = 'Rosalia Natalia';
    
    return `
      <style>
        @media print {
          @page { size: A4 portrait; margin: 0; }
          body { margin: 0; padding: 8mm; }
        }
        .page-break-preview {
          page-break-before: always;
        }
        @media screen {
          .page-break-preview {
            border-top: 2px dashed #cbd5e1;
            margin-top: 30px !important;
            padding-top: 15px !important;
            position: relative;
            page-break-before: auto;
          }
          .page-break-preview::before {
            content: "HALAMAN BARU / NEW PAGE (LAMPIRAN)";
            position: absolute;
            top: -10px;
            left: 20px;
            background: #fff;
            padding: 0 8px;
            font-size: 8px;
            color: #64748b;
            font-weight: bold;
            letter-spacing: 0.5px;
          }
        }
        .esig path {
          fill: none;
          stroke: #1565c0;
          stroke-width: 2.5;
          stroke-linecap: round;
          stroke-linejoin: round;
        }
        .status-pill {
          display: inline-block;
          padding: 1px 6px;
          border-radius: 8px;
          font-size: 7.5px;
          font-weight: bold;
          text-transform: uppercase;
        }
        .status-pill.app { background: #e8f5e9; color: #2e7d32; }
        .status-pill.pend { background: #fff3e0; color: #e65100; }
        .status-pill.rej { background: #ffebee; color: #c62828; }
      </style>
      <div style="font-family:Arial,sans-serif; background:#fff; color:#111; padding:15px; font-size:9.5px; border:1.5px solid #111; box-sizing:border-box; max-width:800px; margin:0 auto;">
        <!-- Header -->
        <table style="width:100%; border-collapse:collapse; border:1.5px solid #111; margin-bottom:12px; background-color:#e0e0e0;">
          <tr>
            <td style="width:15%; text-align:center; border:1.5px solid #111; padding:6px; vertical-align:middle;">
              <img src="data:image/png;base64," style="max-height:100px; max-width:100%; object-fit:contain;" />
            </td>
            <td style="width:48%; border:1px solid #111; padding:6px; vertical-align:middle;">
              <div style="font-size:14px; font-weight:900; color:#c8102e; letter-spacing:0.5px; line-height:1.1;">PT. BHUMI KARYA UTAMA</div>
              <div style="font-size:8px; color:#555; margin-top:4px; line-height:1.3;">
                Jl. Pahlawan No. 128 RT 001 RW 001 Kel. Kec. Panggung - Jakarta Utara 14430<br>Tel : 021-xxxxxxx | Fax : 021-xxxxxxx
              </div>
            </td>
            <td style="width:30%; text-align:center; border:1px solid #111; padding:6px; vertical-align:middle;">
              <div style="font-size:11px; font-weight:bold; color:#555;">PR</div>
              <div style="font-size:14px; font-weight:900; color:#111; margin-top:2px;">PURCHASE REQUEST</div>
            </td>
          </tr>
        </table>
        
        <!-- Info Metadata Table -->
        <table style="width:100%; border-collapse:collapse; border:1px solid #111; margin-bottom:12px;">
          <tr>
            <td style="width:35%; border:1px solid #111; padding:0; vertical-align:top;">
              <table style="width:100%; border-collapse:collapse;">
                <tr><td style="font-weight:bold; color:#444; background:#f5f5f5; width:75px; border-right:1px solid #ddd; padding:4px 6px; border-bottom:1px solid #111;">PR No.</td><td style="border-bottom:1px solid #111; padding:4px; font-weight:bold;">${doc.docNumber}</td></tr>
                <tr><td style="font-weight:bold; color:#444; background:#f5f5f5; width:75px; border-right:1px solid #ddd; padding:4px 6px; border-bottom:1px solid #111;">PR Date</td><td style="border-bottom:1px solid #111; padding:4px;">${formatDate(doc.date)}</td></tr>
                <tr><td style="font-weight:bold; color:#444; background:#f5f5f5; width:75px; border-right:1px solid #ddd; padding:4px 6px;">Department</td><td style="padding:4px;">${doc.dept}</td></tr>
              </table>
            </td>
            <td style="width:18%; text-align:center; border:1px solid #111; padding:0; vertical-align:top;">
              <div style="background:#f5f5f5; border-bottom:1px solid #111; padding:4px; font-weight:bold;">Priority</div>
              <div style="padding:12px 4px; font-size:11px; font-weight:bold; color:#c8102e;">${doc.priority || 'P2'}</div>
            </td>
            <td style="width:22%; border:1px solid #111; padding:0; vertical-align:top;">
              <div style="background:#f5f5f5; border-bottom:1px solid #111; padding:4px; font-weight:bold; text-align:center;">Inventory Type</div>
              <div style="padding:8px 10px; line-height:1.5;">
                <div><span style="display:inline-block; width:10px; height:10px; border:1px solid #111; margin-right:4px; text-align:center; line-height:9px; font-size:8px; font-weight:bold;">${isStock}</span> STOCK</div>
                <div style="margin-top:3px;"><span style="display:inline-block; width:10px; height:10px; border:1px solid #111; margin-right:4px; text-align:center; line-height:9px; font-size:8px; font-weight:bold;">${isNonStock}</span> NON STOCK</div>
              </div>
            </td>
            <td style="width:25%; text-align:center; border:1px solid #111; padding:0; vertical-align:top;">
              <div style="background:#f5f5f5; border-bottom:1px solid #111; padding:4px; font-weight:bold;">Purchase Category</div>
              <div style="padding:12px 4px; font-weight:bold;">${doc.purchaseCategory || 'Office Equipment'}</div>
            </td>
          </tr>
        </table>
        
        <!-- Items Table -->
        <table style="width:100%; border-collapse:collapse; border:1px solid #111; margin-bottom:12px; font-size:9px;">
          <thead>
            <tr>
              <th style="background:#f5f5f5; color:#111; padding:5px; font-weight:bold; text-align:center; border:1px solid #111; text-transform:uppercase;">No.</th>
              <th style="background:#f5f5f5; color:#111; padding:5px; font-weight:bold; text-align:center; border:1px solid #111; text-transform:uppercase;">COA</th>
              <th style="background:#f5f5f5; color:#111; padding:5px; font-weight:bold; text-align:center; border:1px solid #111; text-transform:uppercase;">Part Number</th>
              <th style="background:#f5f5f5; color:#111; padding:5px; font-weight:bold; text-align:left; border:1px solid #111; text-transform:uppercase;">Description</th>
              <th style="background:#f5f5f5; color:#111; padding:5px; font-weight:bold; text-align:center; border:1px solid #111; text-transform:uppercase;">Cost Element</th>
              <th style="background:#f5f5f5; color:#111; padding:5px; font-weight:bold; text-align:center; border:1px solid #111; text-transform:uppercase;">Quantity</th>
              <th style="background:#f5f5f5; color:#111; padding:5px; font-weight:bold; text-align:center; border:1px solid #111; text-transform:uppercase;">UoM</th>
            </tr>
          </thead>
          <tbody>
            ${itemsRowsHTML}
          </tbody>
        </table>
        
        <!-- User For Box -->
        <div style="border:1px solid #111; padding:8px; margin-bottom:12px; background-color:#FFFF00;">
          <strong>User For:</strong><br>
          <div style="margin-top:4px; color:#333;">${doc.userFor || '-'}</div>
        </div>
        
        <div style="font-size:7.5px; color:#666; margin-bottom:12px; font-style:italic;">* Untuk menghindari kesalahan, harap menggunakan bahasa umum yang mudah dimengerti dan menyertakan spesifikasi yang lengkap disertai gambar atau contoh barang</div>
        
        <!-- Signatures Grid -->
        <table style="width:100%; border-collapse:collapse; text-align:center; font-size:9px; margin-top:15px;">
          <thead>
            <tr style="background:#f5f5f5; font-weight:bold;">
              <th style="width:25%; border:1px solid #111; padding:4px;">DIBUAT OLEH</th>
              <th style="width:25%; border:1px solid #111; padding:4px;">DIVERIFIKASI OLEH</th>
              <th style="width:25%; border:1px solid #111; padding:4px;">DIVERIFIKASI OLEH</th>
              <th style="width:25%; border:1px solid #111; padding:4px;">DISETUJUI OLEH</th>
            </tr>
            <tr style="background:#f9f9f9; font-size:8px;">
              <th style="border:1px solid #111; padding:4px;">USER</th>
              <th style="border:1px solid #111; padding:4px;">SUPERVISOR</th>
              <th style="border:1px solid #111; padding:4px;">FINANCE</th>
              <th style="border:1px solid #111; padding:4px;">PROJECT MANAGER</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td style="height:52px; vertical-align:middle; border:1px solid #111; padding:4px;">${sigUser.content}</td>
              <td style="height:52px; vertical-align:middle; border:1px solid #111; padding:4px;">${sigSupervisor.content}</td>
              <td style="height:52px; vertical-align:middle; border:1px solid #111; padding:4px;">${sigFin.content}</td>
              <td style="height:52px; vertical-align:middle; border:1px solid #111; padding:4px;">${sigPm.content}</td>
            </tr>
            <tr style="font-weight:bold; font-size:8.5px;">
              <td style="border:1px solid #111; padding:4px;">${sigUser.name}</td>
              <td style="border:1px solid #111; padding:4px;">${sigSupervisor.name}</td>
              <td style="border:1px solid #111; padding:4px;">${sigFin.name}</td>
              <td style="border:1px solid #111; padding:4px;">${sigPm.name}</td>
            </tr>
            <tr>
              <td style="border:1px solid #111; padding:4px;"><span class="status-pill ${sigUser.statusClass}">${sigUser.statusText}</span></td>
              <td style="border:1px solid #111; padding:4px;"><span class="status-pill ${sigSupervisor.statusClass}">${sigSupervisor.statusText}</span></td>
              <td style="border:1px solid #111; padding:4px;"><span class="status-pill ${sigFin.statusClass}">${sigFin.statusText}</span></td>
              <td style="border:1px solid #111; padding:4px;"><span class="status-pill ${sigPm.statusClass}">${sigPm.statusText}</span></td>
            </tr>
            <tr style="font-size:7.5px; color:#555;">
              <td style="border:1px solid #111; padding:4px;">${sigUser.date || '-'}</td>
              <td style="border:1px solid #111; padding:4px;">${sigSupervisor.date || '-'}</td>
              <td style="border:1px solid #111; padding:4px;">${sigFin.date || '-'}</td>
              <td style="border:1px solid #111; padding:4px;">${sigPm.date || '-'}</td>
            </tr>
          </tbody>
        </table>
        
        ${doc.attachment ? `
          <div class="page-break-preview" style="border:1px solid #111; padding:8px; margin-top:20px;">
            <div style="font-weight:bold; font-size:10px; border-bottom:1px solid #111; padding-bottom:3px; margin-bottom:5px; text-transform:uppercase;">Lampiran / Attachments:</div>
            ${doc.attachment.indexOf('data:application/pdf') === 0 || doc.attachment.toLowerCase().indexOf('.pdf') !== -1 || (doc.attachmentName && doc.attachmentName.toLowerCase().indexOf('.pdf') !== -1) ? 
              (doc.attachment.indexOf('data:application/pdf') === 0 ? 
                `<div class="pdf-rendering-container" data-pdf="${doc.attachment}" style="text-align:center; padding:10px;">Mengurai halaman PDF...</div>` :
                `<div style="padding:10px;"><a href="${doc.attachment}" target="_blank" style="color:#1565c0; text-decoration:underline; font-weight:bold;"><i class="fas fa-external-link-alt"></i> Buka Lampiran PDF (${doc.attachmentName || 'File'})</a></div>`
              ) :
              (doc.attachment.indexOf('data:image') === 0 || doc.attachment.match(/\.(jpeg|jpg|gif|png|webp|svg)/i) || (doc.attachmentName && doc.attachmentName.match(/\.(jpeg|jpg|gif|png|webp|svg)/i)) ? 
                `<div style="text-align:center;"><img src="${doc.attachment}" style="max-height:280px; max-width:100%; object-fit:contain;" /></div>` : 
                `<div style="padding:10px;"><a href="${doc.attachment}" target="_blank" download="${doc.attachmentName || 'lampiran'}" style="color:#1565c0; text-decoration:underline; font-weight:bold;">Unduh Lampiran (${doc.attachmentName || 'File'})</a></div>`
              )
            }
          </div>
        ` : ''}
      </div>
    `;
  } else {
    let itemsRowsHTML = '';
    doc.items.forEach(function(item, idx) {
      itemsRowsHTML += '<tr>' +
        '<td style="border:1px solid #111; padding:4px; text-align:center;">' + (idx + 1) + '</td>' +
        '<td style="border:1px solid #111; padding:4px; text-align:center; font-weight:bold;">' + (item.PC || item.coa || item.COA || '-') + '</td>' +
        '<td style="border:1px solid #111; padding:4px; text-align:center;">' + (item.DR || item.costElement || item.CostElement || '-') + '</td>' +
        '<td style="border:1px solid #111; padding:4px;">' + (item.desc || item.Description || '-') + '</td>' +
        '<td style="border:1px solid #111; padding:4px; text-align:center;">' + (item.qty || item.Quantity || 1) + '</td>' +
        '<td style="border:1px solid #111; padding:4px; text-align:right;">' + formatCurrency(item.price || item.Price || 0).substring(3) + '</td>' +
        '<td style="border:1px solid #111; padding:4px; text-align:right; font-weight:bold;">' + formatCurrency(item.amount || item.Total || 0).substring(3) + '</td>' +
        '<td style="border:1px solid #111; padding:4px;">' + (item.info || item.Information || doc.userFor || '-') + '</td>' +
        '</tr>';
    });
    
    const brPC = doc.budget ? (doc.budget.Project || 'BHL.22.105.001') : 'BHL.22.105.001';
    const brDR = doc.budget ? (doc.budget.Department || 'TOB3,CE0831,LM001,LA01') : 'TOB3,CE0831,LM001,LA01';
    const annualLimit = doc.budget ? (parseFloat(doc.budget.AnnualBudget) || 10000000) : 10000000;
    const actualSpent = doc.budget ? (parseFloat(doc.budget.ActualBudget) || 1650000) : 1650000;
    const budgetAvail = annualLimit - actualSpent;
    const budgetVariant = budgetAvail - doc.nominal;
    const brVariantColor = budgetVariant >= 0 ? '#2e7d32' : '#c62828';
    
    const sigPrepared = getSigBoxData(sigs.user, 'user');
    const sigVerified = getSigBoxData(sigs.headDept, 'headDept');
    const sigApprovedPm = getSigBoxData(sigs.projectManager, 'projectManager');
    const sigCheckedFin = getSigBoxData(sigs.finance, 'finance');
    const sigCheckedCc = getSigBoxData(sigs.costControl, 'costControl');
    const sigCheckedAcc = getSigBoxData(sigs.accountingHO || {}, 'accountingHO');
    const sigDisbPm = getSigBoxData(sigs.gmDept || {}, 'gmDept');
    const sigDisbCfo = getSigBoxData(sigs.gmCfo, 'gmCfo');
    
    if (sigPrepared.name === '-') sigPrepared.name = doc.requester || 'Mona Asrani';
    if (sigVerified.name === '-') sigVerified.name = getSignerName('Head Department', doc.dept || 'HRGA', 'Rosalia Natalia');
    if (sigApprovedPm.name === '-') sigApprovedPm.name = getSignerName('Project Manager', 'Operation', 'Yohanes Sam');
    if (sigCheckedFin.name === '-') sigCheckedFin.name = getSignerName('Finance', 'Finance', 'Putri Amalia/Fakihun');
    if (sigCheckedCc.name === '-') sigCheckedCc.name = getSignerName('Cost Control', 'Finance', 'Janrizal/Dwi Wibowo');
    if (sigCheckedAcc.name === '-') sigCheckedAcc.name = getSignerName('Accounting HO', 'Finance', 'Arista/Sinta Agnes');
    if (sigDisbPm.name === '-') sigDisbPm.name = getSignerName('GM/CFO', 'Management', 'Sjamsi Josal');
    if (sigDisbCfo.name === '-') sigDisbCfo.name = getSignerName('COO', 'Management', 'Fransiscus Vici S.');
    
    return `
      <style>
        @media print {
          @page { size: A4 landscape; margin: 0; }
          body { margin: 0; padding: 8mm; }
        }
        .page-break-preview {
          page-break-before: always;
        }
        @media screen {
          .page-break-preview {
            border-top: 2px dashed #cbd5e1;
            margin-top: 30px !important;
            padding-top: 15px !important;
            position: relative;
            page-break-before: auto;
          }
          .page-break-preview::before {
            content: "HALAMAN BARU / NEW PAGE (LAMPIRAN)";
            position: absolute;
            top: -10px;
            left: 20px;
            background: #fff;
            padding: 0 8px;
            font-size: 8px;
            color: #64748b;
            font-weight: bold;
            letter-spacing: 0.5px;
          }
        }
        .esig path {
          fill: none;
          stroke: #1565c0;
          stroke-width: 2.5;
          stroke-linecap: round;
          stroke-linejoin: round;
        }
        .status-pill {
          display: inline-block;
          padding: 1px 6px;
          border-radius: 8px;
          font-size: 7.5px;
          font-weight: bold;
          text-transform: uppercase;
        }
        .status-pill.app { background: #e8f5e9; color: #2e7d32; }
        .status-pill.pend { background: #fff3e0; color: #e65100; }
        .status-pill.rej { background: #ffebee; color: #c62828; }
      </style>
      <div style="font-family:Arial,sans-serif; background:#fff; color:#111; padding:10px; font-size:9px; border:1.5px solid #111; box-sizing:border-box; max-width:1080px; margin:0 auto;">
        <!-- Header -->
        <table style="width:100%; border-collapse:collapse; border:1.5px solid #111; margin-bottom:8px;">
          <tr>
            <td style="width:25%; text-align:center; border:1px solid #111; padding:6px; vertical-align:middle;">
              <img src="data:image/jpeg;base64," style="max-height:95px; max-width:100%; object-fit:contain; display:block; margin:0 auto 3px auto;" />
              <div style="font-size:8px; color:#111; font-weight:bold; line-height:1.2;">PT. BARA INDAH SINERGI</div>
            </td>
            <td style="width:45%; text-align:center; border:1px solid #111; padding:6px; vertical-align:middle;">
              <div style="font-size:9px; color:#555; font-weight:bold; letter-spacing:1px;">FORMULIR</div>
              <div style="font-size:15px; font-weight:900; color:#111; letter-spacing:0.5px; margin-top:2px;">PERMOHONAN DANA</div>
              <div style="font-size:10px; color:#555; margin-top:2px; font-style:italic;">(Dana Operasional &amp; Petty Cash)</div>
            </td>
            <td style="width:30%; padding:0; border:1px solid #111; vertical-align:middle;">
              <table style="width:100%; border-collapse:collapse;">
                <tr><td style="font-weight:bold; color:#444; background:#f5f5f5; width:80px; border-right:1px solid #ddd; padding:3px 5px; border-bottom:1px solid #eee;">No Dokumen</td><td style="border-bottom:1px solid #eee; padding:3px 5px; font-weight:bold;">BIS.FR.FAT.001</td></tr>
                <tr><td style="font-weight:bold; color:#444; background:#f5f5f5; width:80px; border-right:1px solid #ddd; padding:3px 5px; border-bottom:1px solid #eee;">Tanggal Efektif</td><td style="border-bottom:1px solid #eee; padding:3px 5px;">01-Jan-26</td></tr>
                <tr><td style="font-weight:bold; color:#444; background:#f5f5f5; width:80px; border-right:1px solid #ddd; padding:3px 5px; border-bottom:1px solid #eee;">Revisi</td><td style="border-bottom:1px solid #eee; padding:3px 5px;">01</td></tr>
                <tr><td style="font-weight:bold; color:#444; background:#f5f5f5; width:80px; border-right:1px solid #ddd; padding:3px 5px;">Halaman</td><td style="padding:3px 5px;">1 dari 1</td></tr>
              </table>
            </td>
          </tr>
        </table>
        
        <!-- Metadata table rows -->
        <table style="width:100%; border-collapse:collapse; border:1px solid #111; margin-bottom:8px; font-size:9.5px;">
          <tr>
            <td style="font-weight:bold; color:#444; background:#f5f5f5; width:12%; border:1px solid #111; padding:4px;">NO</td>
            <td style="width:3%; text-align:center; font-weight:bold; border:1px solid #111; padding:4px;">:</td>
            <td style="font-weight:bold; color:#111; border:1px solid #111; padding:4px;">${doc.docNumber}</td>
          </tr>
          <tr>
            <td style="font-weight:bold; color:#444; background:#f5f5f5; width:12%; border:1px solid #111; padding:4px;">TGL</td>
            <td style="text-align:center; font-weight:bold; border:1px solid #111; padding:4px;">:</td>
            <td style="border:1px solid #111; padding:4px;">${formatDate(doc.date)}</td>
          </tr>
          <tr>
            <td style="font-weight:bold; color:#444; background:#f5f5f5; width:12%; border:1px solid #111; padding:4px;">DEPT</td>
            <td style="text-align:center; font-weight:bold; border:1px solid #111; padding:4px;">:</td>
            <td style="border:1px solid #111; padding:4px;">${doc.dept}</td>
          </tr>
          <tr>
            <td style="font-weight:bold; color:#444; background:#f5f5f5; width:12%; border:1px solid #111; padding:4px;">SUBJECT</td>
            <td style="text-align:center; font-weight:bold; border:1px solid #111; padding:4px;">:</td>
            <td style="font-weight:bold; border:1px solid #111; padding:4px;">${doc.subject}</td>
          </tr>
        </table>
        
        <!-- Items Table -->
        <table style="width:100%; border-collapse:collapse; border:1px solid #111; margin-bottom:8px;">
          <thead>
            <tr>
              <th style="background:#f5f5f5; color:#111; padding:4px; font-weight:bold; border:1px solid #111; font-size:9px; text-transform:uppercase; width:4%;">NO</th>
              <th style="background:#f5f5f5; color:#111; padding:4px; font-weight:bold; border:1px solid #111; font-size:9px; text-transform:uppercase; width:8%;">PC<br><small style="font-weight:normal; font-size:7.5px;">(PROJECT CODE)</small></th>
              <th style="background:#f5f5f5; color:#111; padding:4px; font-weight:bold; border:1px solid #111; font-size:9px; text-transform:uppercase; width:10%;">DR<br><small style="font-weight:normal; font-size:7.5px;">(DISTRIBUTION RULES)<br>*Diisi Oleh Cost Control</small></th>
              <th style="background:#f5f5f5; color:#111; padding:4px; font-weight:bold; border:1px solid #111; font-size:9px; text-transform:uppercase;">DESCRIPTION</th>
              <th style="background:#f5f5f5; color:#111; padding:4px; font-weight:bold; border:1px solid #111; font-size:9px; text-transform:uppercase; width:6%;">QTY</th>
              <th style="background:#f5f5f5; color:#111; padding:4px; font-weight:bold; border:1px solid #111; font-size:9px; text-transform:uppercase; width:12%;">PRICE</th>
              <th style="background:#f5f5f5; color:#111; padding:4px; font-weight:bold; border:1px solid #111; font-size:9px; text-transform:uppercase; width:14%;">AMOUNT (IDR)</th>
              <th style="background:#f5f5f5; color:#111; padding:4px; font-weight:bold; border:1px solid #111; font-size:9px; text-transform:uppercase; width:16%;">INFORMATION</th>
            </tr>
          </thead>
          <tbody>
            ${itemsRowsHTML}
            <tr style="font-weight:bold; background:#f5f5f5;">
              <td colspan="5" style="border:1px solid #111; padding:4px; text-align:right;">TOTAL PERMOHONAN DANA :</td>
              <td style="border:1px solid #111; padding:4px; text-align:center;">Rp</td>
              <td style="border:1px solid #111; padding:4px; text-align:right; color:#c8102e;">${formatCurrency(doc.nominal).substring(3)}</td>
              <td style="border:1px solid #111; padding:4px;"></td>
            </tr>
          </tbody>
        </table>
        
        <!-- Terbilang Box -->
        <div style="background:#fafafa; border:1px solid #ddd; padding:6px 10px; font-size:9px; margin-bottom:8px;">Terbilang : <strong>${terbilangText} rupiah</strong></div>
        
        <!-- Budget Review -->
        <div style="font-size:8.5px; font-weight:bold; margin-bottom:4px;">Budget Review <span style="font-weight:normal; font-style:italic; color:#666;">*Diisi Oleh Cost Control</span></div>
        <table style="width:100%; border-collapse:collapse; border:1px solid #111; text-align:center; margin-bottom:8px;">
          <thead>
            <tr>
              <th style="background:#e3f2fd; color:#111; border:1px solid #111; padding:4px; font-size:9px; font-weight:bold; width:20%;">PC</th>
              <th style="background:#e3f2fd; color:#111; border:1px solid #111; padding:4px; font-size:9px; font-weight:bold; width:22%;">DR</th>
              <th style="background:#e3f2fd; color:#111; border:1px solid #111; padding:4px; font-size:9px; font-weight:bold; width:20%;">Budget Available</th>
              <th style="background:#e3f2fd; color:#111; border:1px solid #111; padding:4px; font-size:9px; font-weight:bold; width:20%;">Budget Actual</th>
              <th style="background:#e3f2fd; color:#111; border:1px solid #111; padding:4px; font-size:9px; font-weight:bold; width:18%;">Variant (a-b)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td style="font-weight:bold; border:1px solid #111; padding:4px;"></td>
              <td style="border:1px solid #111; padding:4px;"></td>
              <td style="font-weight:bold; border:1px solid #111; padding:4px;"></td>
              <td style="border:1px solid #111; padding:4px;"></td>
              <td style="font-weight:bold; border:1px solid #111; padding:4px;"></td>
            </tr>
          </tbody>
        </table>
        
        <!-- Signatures Grid -->
        <table style="width:100%; border-collapse:collapse; text-align:center; font-size:8.5px; table-layout:fixed;">
          <thead>
            <tr style="background:#f5f5f5; font-weight:bold;">
              <th style="width:12.5%; border:1px solid #111; padding:3px;">Prepared By,</th>
              <th style="width:12.5%; border:1px solid #111; padding:3px;">Verified By,</th>
              <th style="width:12.5%; border:1px solid #111; padding:3px;">Approved By,</th>
