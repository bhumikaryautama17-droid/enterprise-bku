/**
 * PDF FINAL ARCHIVE VIEW LOGIC (LIVE VERSION)
 */
function initPDFArchivePage() {
  if (document.getElementById('pdf-filter-type')) document.getElementById('pdf-filter-type').value = '';
  if (document.getElementById('pdf-filter-dept')) {
    const isFinanceOrAdmin = currentUser && (
      currentUser.role === 'Finance' || 
      currentUser.department === 'Finance' || 
      currentUser.role === 'Administrator' || 
      currentUser.department === 'IT'
    );
    if (!isFinanceOrAdmin && currentUser && currentUser.department) {
      document.getElementById('pdf-filter-dept').value = currentUser.department;
      document.getElementById('pdf-filter-dept').disabled = true;
    } else {
      document.getElementById('pdf-filter-dept').value = '';
      document.getElementById('pdf-filter-dept').disabled = false;
    }
  }
  if (document.getElementById('pdf-filter-month')) document.getElementById('pdf-filter-month').value = '';
  if (document.getElementById('pdf-filter-year')) document.getElementById('pdf-filter-year').value = '';
  if (document.getElementById('pdf-filter-search')) document.getElementById('pdf-filter-search').value = '';
  loadPDFArchive();
}

function loadPDFArchive() {
  const typeFilter = document.getElementById('pdf-filter-type') ? document.getElementById('pdf-filter-type').value : '';
  const deptFilter = document.getElementById('pdf-filter-dept') ? document.getElementById('pdf-filter-dept').value : '';
  const monthFilter = document.getElementById('pdf-filter-month') ? document.getElementById('pdf-filter-month').value : '';
  const yearFilter = document.getElementById('pdf-filter-year') ? document.getElementById('pdf-filter-year').value : '';
  const searchFilter = document.getElementById('pdf-filter-search') ? document.getElementById('pdf-filter-search').value.toLowerCase().trim() : '';

  showLoading(true);
  google.script.run.withSuccessHandler(function(list) {
    showLoading(false);
    
    // Apply additional search filter locally on document number or subject
    let filteredList = list;
    if (searchFilter) {
      filteredList = list.filter(function(req) {
        const docNo = (req.docNumber || '').toLowerCase();
        const subject = (req.subject || '').toLowerCase();
        return docNo.includes(searchFilter) || subject.includes(searchFilter);
      });
    }
    
    renderPDFArchiveTable(filteredList);
  }).withFailureHandler(function(err) {
    showLoading(false);
    alert(err.toString());
  }).getDocumentHistory(typeFilter, 'Approved', deptFilter, monthFilter, yearFilter);
}

function renderPDFArchiveTable(list) {
  const tbody = document.getElementById('pdfArchiveTbody');
  tbody.innerHTML = '';
  if (list.length === 0) {
    tbody.innerHTML = `<tr><td colspan="6" style="text-align:center; padding:16px;">No documents found matching filters</td></tr>`;
    return;
  }
  
  list.forEach((req, idx) => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${idx + 1}</td>
      <td><b>${req.docNumber}</b></td>
      <td><span class="status-pill ${req.type.toLowerCase() === 'pr' ? 'pending' : 'approved'}">${req.type}</span></td>
      <td>${req.subject.slice(0,40)}</td>
      <td>${req.date}</td>
      <td>
        <button class="form-btn" style="padding: 4px 10px;" onclick="openApprovalModal('${req.id}')"><i class="fas fa-eye"></i> Preview</button>
      </td>
    `;
    tbody.appendChild(tr);
  });
}

